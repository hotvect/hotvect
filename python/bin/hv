    def get_source_path_config(self):
        return True, "Path to the input data source for prediction (required)"


class ListTransformationsCommand(JavaCommand):
    def get_name(self) -> str:
        return "list-transformations"

    def get_help(self) -> str:
        return "Display all feature transformations defined in the algorithm"

    def get_description(self) -> str:
        return "List all feature transformations, encoders, and data processing steps available in the specified algorithm. Use --verbose for detailed information about each transformation including parameters and data types."

    def get_source_path_config(self):
        return False, "Path to the input data source (optional for list-transformations)"

    def add_command_arguments(self, parser: argparse.ArgumentParser) -> None:
        parser.add_argument("--verbose", action='store_true',
                          help="Show detailed information about each transformation including parameters and data types (optional)")




class EvaluateCommand(BaseCommand):
    def get_name(self) -> str:
        return "evaluate"

    def get_help(self) -> str:
        return "Calculate performance metrics from model predictions"

    def get_description(self) -> str:
        return "Compute evaluation metrics (accuracy, precision, recall, AUC, etc.) from prediction results. Can perform both online/offline analysis to compare model performance across different scenarios and data splits."

    def add_arguments(self, parser: argparse.ArgumentParser) -> None:
        parser.add_argument("--source-path", required=True,
                          help="Path to the prediction results file (JSONL format) to evaluate (required)")
        parser.add_argument("--dest-path", required=True,
                          help="Path where the evaluation metrics will be saved as JSON (required)")
        parser.add_argument("--enable-online-offline-analysis", action='store_true',
                          help="Enable detailed online vs offline performance analysis (optional)")

    def execute(self, args: argparse.Namespace) -> None:
        perform_online_offline_evaluations = args.enable_online_offline_analysis
        result = mlutils.standard_evaluation(
            path=args.source_path
        )
        with open(args.dest_path, 'w') as f:
            json.dump(result, f, indent=2)
        print(f"Evaluation results saved to {args.dest_path}")


class TrainCommand(BaseCommand):
    def get_name(self) -> str:
        return "train"

    def get_help(self) -> str:
        return "Train a machine learning model using the hotvect pipeline"

    def get_description(self) -> str:
        return "Train a machine learning model using the hotvect pipeline with specified algorithm and data paths"

    def add_arguments(self, parser: argparse.ArgumentParser) -> None:
        parser.add_argument("--algorithm-name", required=True,
                          help="Name of the algorithm to train (required)")
        parser.add_argument("--data-base-dir", required=True,
                          help="Base directory containing training data (required)")
        parser.add_argument("--output-base-dir", required=True,
                          help="Base directory where training outputs will be saved (required)")
        parser.add_argument("--algorithm-jar", required=True,
                          help="Path to the JAR file containing the algorithm implementation (required)")
        parser.add_argument("--last-test-time", required=True,
                          help="Last test time in YYYY-MM-DD format, e.g., '2025-04-30' (required)")
        parser.add_argument("--algorithm-override",
                          help="Path to JSON file containing algorithm configuration overrides (optional)")
        parser.add_argument("--extra-jvm-args",
                          help="Additional JVM arguments for training, comma-separated, e.g., '-Xmx64g,-XX:+UseG1GC' (optional)")

    def execute(self, args: argparse.Namespace) -> None:
        # Parse extra JVM args if provided
        jvm_options = ["-Xmx32g"]  # Default JVM memory
        if args.extra_jvm_args:
            extra_jvm_args = [arg.strip() for arg in args.extra_jvm_args.split(',')]
            jvm_options.extend(extra_jvm_args)

        # Create the pipeline context
        context = AlgorithmPipelineContext(
            algorithm_jar_path=Path(args.algorithm_jar),
            state_source_base_path=Path(args.data_base_dir),
            data_base_path=Path(args.data_base_dir),
            metadata_base_path=Path(args.output_base_dir) / "metadata",
            output_base_path=Path(args.output_base_dir),
            jvm_options=jvm_options,
            enable_gzip=False,
            max_threads=5
        )

        logger.info(f"Starting training for algorithm: {args.algorithm_name}")
        logger.info(f"Data base directory: {args.data_base_dir}")
        logger.info(f"Output base directory: {args.output_base_dir}")
        logger.info(f"Algorithm JAR: {args.algorithm_jar}")

        # Parse last test time
        from datetime import date
        last_test_time = date.fromisoformat(args.last_test_time)

        # Handle algorithm definition with optional overrides
        algorithm_definition = args.algorithm_name
        if args.algorithm_override:
            import json
            logger.info(f"Loading algorithm overrides from: {args.algorithm_override}")
            with open(args.algorithm_override, 'r') as f:
                override_config = json.load(f)
            algorithm_definition = (args.algorithm_name, override_config)
            logger.info(f"Applied algorithm overrides: {override_config}")

        # Create and run the pipeline
        from hotvect.mlutils import standard_evaluation

        pipeline = AlgorithmPipeline(
            algorithm_pipeline_context=context,
            algorithm_definition=algorithm_definition,
            last_test_time=last_test_time,
            evaluation_func=standard_evaluation
        )
        pipeline.run_all()

        logger.info("Training pipeline completed successfully")


class BacktestCommand(BaseCommand):
    def get_name(self) -> str:
        return "backtest"

    def get_help(self) -> str:
        return "Run backtest on git references to compare algorithm performance"

    def get_description(self) -> str:
        return "Run backtest on git references to compare algorithm performance across different versions or configurations. For SageMaker execution, returns immediately after job submission without waiting for completion."

    def add_arguments(self, parser: argparse.ArgumentParser) -> None:
        # Create mutually exclusive group for git references
        ref_group = parser.add_mutually_exclusive_group(required=True)
        ref_group.add_argument("--git-reference", action='append', dest='git_references',
                              help="Git reference (branch/commit) to test. Can be specified multiple times for multiple references")
        ref_group.add_argument("--backtest-config",
                              help="Path to JSON file containing list of git references and their overrides")

        parser.add_argument("--algorithm-override", action='append', dest='algorithm_overrides',
                          help="Path to JSON file containing algorithm configuration overrides. If one override provided, applies to all git references. If multiple overrides provided, applies to git references in order (optional)")

        # Required arguments
        parser.add_argument("--algo-repo-url", required=True,
                          help="Git repository URL for the algorithm (required)")
        parser.add_argument("--data-base-dir",
                          help="Base directory containing training and test data (required for local execution, optional for SageMaker - data comes from S3 channels in SageMaker config)")
        parser.add_argument("--output-base-dir", required=True,
                          help="Base directory where backtest results will be saved (required)")
        parser.add_argument("--scratch-dir", required=True,
                          help="Directory for temporary files like JARs and working data during backtest execution (required)")
        parser.add_argument("--last-test-time", required=True,
                          help="Last test time in YYYY-MM-DD format, e.g., '2025-08-05' (required)")

        # Optional arguments
        parser.add_argument("--number-of-runs", type=int, default=1,
                          help="Number of backtest runs to execute (default: 1)")
        parser.add_argument("--extra-jvm-args",
                          help="Additional JVM arguments, comma-separated, e.g., '-Xmx176g,-XX:+UseG1GC' (optional)")
        parser.add_argument("--sagemaker-config",
                          help="Path to JSON file containing SageMaker training job configuration (optional)")
        parser.add_argument("--role-arn",
                          help="AWS role ARN to assume for SageMaker execution (optional)")
        parser.add_argument("--n-process", type=int, default=1,
                          help="Number of parallel processes for local execution (default: 1)")
        parser.add_argument("--max-threads-per-process", type=int, default=-1,
                          help="Maximum threads per process for local execution (default: auto-calculated)")
        parser.add_argument("--clean", action='store_true',
                          help="Clean output directories before starting backtest (optional)")
        parser.add_argument("--no-performance-test", action='store_true',
                          help="Disable system performance testing (optional)")
        parser.add_argument("--auto-attach-data", action='store_true',
                          help="Automatically populate SageMaker InputDataConfig based on algorithm dependencies (SageMaker mode only)")
        parser.add_argument("--auto-attach-data-default-s3-base",
                          help="Default S3 base URI used when dependencies do not specify explicit s3_uri (e.g., s3://bucket/tables/)")
        parser.add_argument("--auto-attach-data-environment", choices=['production', 'test'], default='production',
                          help="Environment key to use when dependency s3_uri is a map (default: production)")

    def execute(self, args: argparse.Namespace) -> None:
        from datetime import date
        from hotvect.mlutils import standard_evaluation
        import json

        # Parse git references and overrides
        if args.backtest_config:
            # Load from config file
            with open(args.backtest_config, 'r') as f:
                config = json.load(f)
            git_references = [(item['git_reference'], item.get('algorithm_definition_override')) for item in config]
        else:
            # Build from command line arguments
            git_references = []
            overrides = args.algorithm_overrides or []

            # Smart padding logic and validation
            if len(overrides) == 1 and len(args.git_references) > 1:
                logger.info(f"Single algorithm override provided for {len(args.git_references)} git references. Applying the same override to all references: {overrides[0]}")
                # Pad with the single override instead of None
                while len(overrides) < len(args.git_references):
                    overrides.append(overrides[0])
            elif len(overrides) > 1 and len(overrides) != len(args.git_references):
                # Multiple overrides provided but count doesn't match git references - fail
                import sys
                print(f"Error: {len(overrides)} algorithm overrides provided but {len(args.git_references)} git references specified. Numbers don't match.", file=sys.stderr)
                sys.exit(2)
            else:
                # Either no overrides, or exact match, or single git ref - use original padding logic
                while len(overrides) < len(args.git_references):
                    overrides.append(None)

            for i, git_ref in enumerate(args.git_references):
                override = None
                if i < len(overrides) and overrides[i]:
                    with open(overrides[i], 'r') as f:
                        override = json.load(f)
                    logger.info(f"Applied algorithm override from {overrides[i]} to git reference {git_ref}")
                else:
                    logger.info(f"No algorithm override applied to git reference {git_ref}")
                git_references.append((git_ref, override))

        # Parse JVM options
        jvm_options = None
        if args.extra_jvm_args:
            jvm_options = [arg.strip() for arg in args.extra_jvm_args.split(',')]

        # Parse SageMaker config
        sagemaker_training_job_definition = None
        if args.sagemaker_config:
            with open(args.sagemaker_config, 'r') as f:
                sagemaker_training_job_definition = json.load(f)

        # Validate data-base-dir requirement
        if not sagemaker_training_job_definition and not args.data_base_dir:
            import sys
            print("Error: --data-base-dir is required for local execution (when not using --sagemaker-config)", file=sys.stderr)
            sys.exit(2)

        # For SageMaker mode, use placeholder if data_base_dir not provided
        if sagemaker_training_job_definition and not args.data_base_dir:
            args.data_base_dir = args.scratch_dir  # Use scratch dir as placeholder

        # Parse last test time
        last_test_time = date.fromisoformat(args.last_test_time)

        logger.info(f"Starting backtest with {len(git_references)} git references")
        logger.info(f"Git references: {[ref[0] for ref in git_references]}")
        logger.info(f"SageMaker mode: {'enabled' if sagemaker_training_job_definition else 'disabled'}")

        from hotvect.backtest import run_backtest_on_git_references

        # Use the existing run_backtest_on_git_references function which has proper job naming
        results = run_backtest_on_git_references(
            algo_repo_url=args.algo_repo_url,
            algo_git_references=git_references,
            data_base_dir=args.data_base_dir,
            output_base_dir=args.output_base_dir,
            hyperparameter_base_dir=args.scratch_dir,
            evaluation_function=standard_evaluation,
            last_test_time=last_test_time,
            number_of_runs=args.number_of_runs,
            jvm_options=jvm_options,
            sagemaker_training_job_definition=sagemaker_training_job_definition,
            role_arn_to_assume=args.role_arn,
            clean=args.clean,
            system_performance_test=not args.no_performance_test,
            auto_attach_data=args.auto_attach_data,
            auto_attach_data_default_s3_base=args.auto_attach_data_default_s3_base,
            auto_attach_data_environment=args.auto_attach_data_environment,
        )

        # Display results
        if sagemaker_training_job_definition:
            logger.info("SageMaker jobs submitted successfully!")
            for result in results:
                logger.info(f"Git reference: {result.algo_git_reference}")
                if result.error:
                    logger.error(f"Error: {result.error}")
                elif result.backtest_iteration_results:
                    for iteration in result.backtest_iteration_results:
                        if iteration.result and 'training_job_name' in iteration.result:
                            logger.info(f"  SageMaker job submitted: {iteration.result['training_job_name']}")
        else:
            logger.info("Local backtest completed!")
            for result in results:
                logger.info(f"Git reference: {result.algo_git_reference}")
                if result.error:
                    logger.error(f"Error: {result.error}")
                elif result.backtest_iteration_results:
                    for iteration in result.backtest_iteration_results:
                        if iteration.result:
                            logger.info(f"Results for {iteration.parameter_version}: {iteration.result}")

        logger.info("Backtest execution completed")



def main():
    # Define available commands
    commands = {
        'audit': AuditCommand(),
        'performance-test': PerformanceTestCommand(),
        'encode': EncodeCommand(),
        'predict': PredictCommand(),
        'list-transformations': ListTransformationsCommand(),
        'evaluate': EvaluateCommand(),
        'train': TrainCommand(),
        'backtest': BacktestCommand()
    }

    parser = argparse.ArgumentParser(
        prog='hv',
        description="Hotvect Command Line Interface (CLI) tool for performing various operations like encoding, predicting, auditing, etc.",
        epilog="Use 'hv <command> -h' to see help for each command.",
        add_help=True
    )

    subparsers = parser.add_subparsers(dest='command', help='Available subcommands')

    # Add subparsers for each command
    for command_name, command_instance in commands.items():
        subparser = subparsers.add_parser(
            command_name,
            help=command_instance.get_help(),
            description=command_instance.get_description()
        )
        command_instance.add_arguments(subparser)

    # If no arguments are provided, show the help message
    if len(sys.argv) == 1:
        parser.print_help(sys.stderr)
        sys.exit(1)

    # Parse known args to separate command args from JVM args
    args, jvm_args = parser.parse_known_args()

    # Store JVM args for Java commands
    args._jvm_args = jvm_args

    # Execute the selected command
    if args.command in commands:
        commands[args.command].execute(args)
    else:
        parser.error(f"Unknown command {args.command}")


if __name__ == '__main__':
    main()
