_LOG_FORMAT = "%(asctime)s:%(levelname)s:%(name)s:%(funcName)s:%(message)s"

logging.basicConfig(
    level=logging.INFO,
    stream=sys.stdout,
    format=_LOG_FORMAT
)
logger = logging.getLogger(__name__)

_DEFAULT_HV_LOG_FILENAME = "hv.log"
_DEFAULT_STDOUT_STDERR_LOG_FILENAME = "stdout-stderr.log"
_REMOTE_BACKTEST_SUBMISSION_DIRNAME = "_backtest_submissions"
_REMOTE_BACKTEST_SUBMISSION_MANIFEST_FILENAME = "backtest_submission_manifest.json"
_REMOTE_BACKTEST_SUBMISSION_STATUS_FILENAME = "backtest_submission_status.json"
_SOURCE_PREFLIGHT_ACCESS_DENIED_CODES = {"AccessDenied", "AccessDeniedException", "AllAccessDisabled", "403"}
_ALGORITHM_OVERRIDE_HELP = (
    "Path to JSON override patch. Object fields merge recursively, scalars/arrays replace, "
    "null deletes fields, and dependencies.<child> may only target declared children."
)


def _enable_file_logging(log_dir: Path) -> None:
    log_dir.mkdir(parents=True, exist_ok=True)
    log_path = (log_dir / _DEFAULT_HV_LOG_FILENAME).resolve()
    root_logger = logging.getLogger()
    for handler in root_logger.handlers:
        if isinstance(handler, logging.FileHandler) and Path(handler.baseFilename).resolve() == log_path:
            return

    file_handler = logging.FileHandler(log_path, mode="a", encoding="utf-8")
    file_handler.setLevel(logging.INFO)
    file_handler.setFormatter(logging.Formatter(_LOG_FORMAT))
    root_logger.addHandler(file_handler)
    logger.info("Python logs: %s", log_path)


def _tee_subprocess_output_to_metadata_dir(
    cmd: list[str],
    metadata_dir: Path,
    env: dict[str, str] | None = None,
) -> None:
    from hotvect.utils import stream_output

    metadata_dir.mkdir(parents=True, exist_ok=True)
    stdout_stderr_log_path = (metadata_dir / _DEFAULT_STDOUT_STDERR_LOG_FILENAME).resolve()
    with open(stdout_stderr_log_path, "a", encoding="utf-8") as fp:
        def _display(chunk: str) -> None:
            sys.stdout.write(chunk)
            fp.write(chunk)
            fp.flush()

        stream_output(cmd, _display, env=env)

def _parse_algorithm_name(value: str) -> str:
    """
    Parse and validate `--algorithm-name`.

    hv intentionally only accepts an algorithm name here (not an algorithm-definition JSON path).
    Use `--algorithm-override` for JSON override fragments that are merged into the JAR definition.
    """
    lowered = value.lower()
    if lowered.endswith(".json") or "/" in value or "\\" in value:
        raise argparse.ArgumentTypeError(
            f"--algorithm-name must be an algorithm name (not a file path): {value}. "
            f"Use --algorithm-override to pass a JSON override fragment."
        )

    from hotvect.utils import verify_algorithm_name

    try:
        return verify_algorithm_name(value)
    except ValueError as e:
        raise argparse.ArgumentTypeError(str(e)) from e


def _get_hotvect_jar_version() -> str:
    jar_path = _hotvectjar_module().HOTVECT_JAR_PATH
    pom_properties_path = "META-INF/maven/com.hotvect/hotvect-offline-util/pom.properties"
    with zipfile.ZipFile(jar_path) as jar:
        contents = jar.read(pom_properties_path).decode("utf-8")

    for line in contents.splitlines():
        key, sep, value = line.partition("=")
        if sep and key.strip() == "version":
            return value.strip()

    raise ValueError(f"Expected 'version=' in {pom_properties_path} inside {jar_path}")


def _hotvectjar_module():
    import hotvect.hotvectjar as hotvectjar

    return hotvectjar


def _exit_cli_usage_error(message: str) -> None:
    print(f"Error: {message}", file=sys.stderr)
    raise SystemExit(2)


def _extract_remote_backtest_submission_rows(results) -> list[dict[str, Any]]:
    rows: list[dict[str, Any]] = []
    for result in results:
        if result.error or not result.backtest_iteration_results:
            continue
        for iteration in result.backtest_iteration_results:
            if not iteration.result:
                continue
            row = {
                "algo_git_reference": result.algo_git_reference,
                "parameter_version": iteration.parameter_version,
                "test_data_time": iteration.test_data_time,
            }
            row.update(iteration.result)
            rows.append(row)
    return rows


def _remote_backtest_submission_run_dir(output_base_dir: str, generated_at: datetime) -> Path:
    run_id = generated_at.strftime("%Y%m%dT%H%M%S.%fZ")
    return Path(output_base_dir) / "meta" / _REMOTE_BACKTEST_SUBMISSION_DIRNAME / run_id


def _write_remote_backtest_submission_files(output_base_dir: str, results) -> tuple[Path, Path]:
    manifest_rows = _extract_remote_backtest_submission_rows(results)
    generated_at = datetime.now(timezone.utc)
    run_dir = _remote_backtest_submission_run_dir(output_base_dir, generated_at)
    run_dir.mkdir(parents=True, exist_ok=False)
    generated_at_iso = generated_at.isoformat()
    manifest_payload = {
        "generated_at": generated_at_iso,
        "job_count": len(manifest_rows),
        "jobs": manifest_rows,
    }
    status_payload = {
        "generated_at": generated_at_iso,
        "job_count": len(manifest_rows),
        "jobs": [
            {
                "algo_git_reference": row["algo_git_reference"],
                "parameter_version": row["parameter_version"],
                "test_data_time": row["test_data_time"],
                "training_job_name": row.get("training_job_name"),
                "training_job_arn": row.get("training_job_arn"),
                "submission_status": row.get("submission_status"),
                "s3_uri_result_file": row.get("s3_uri_result_file"),
                "s3_uri_metadata": row.get("s3_uri_metadata"),
            }
            for row in manifest_rows
        ],
    }
    manifest_path = run_dir / _REMOTE_BACKTEST_SUBMISSION_MANIFEST_FILENAME
    status_path = run_dir / _REMOTE_BACKTEST_SUBMISSION_STATUS_FILENAME
    manifest_path.write_text(json.dumps(manifest_payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    status_path.write_text(json.dumps(status_payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    return manifest_path, status_path


def _require_s3_dest_path(dest_path: str | None) -> str:
    if not dest_path:
        raise ValueError("--dest-path is required for parallel SageMaker one-shot execution")
    if not str(dest_path).startswith("s3://"):
        raise ValueError("--dest-path must be an s3:// prefix for parallel SageMaker one-shot execution")
    return dest_path


def _parallel_verify_command(command_name: str, args: argparse.Namespace) -> str:
    parts = [
        "hv",
        command_name,
        "--sagemaker",
        "--verify",
        "--dest-path",
        shlex.quote(str(args.dest_path)),
        "--s3-output-base",
        shlex.quote(str(args.s3_output_base)),
    ]
    if getattr(args, "assume_role_arn", None):
        parts.extend(["--assume-role-arn", shlex.quote(str(args.assume_role_arn))])
    return " ".join(parts)


def _parallel_kind_short(task_kind_short: str, shard_index: int) -> str:
    return f"{task_kind_short[:4]}s{shard_index:02d}"


def _nested_get(mapping: dict[str, Any], *keys: str) -> Any:
    current: Any = mapping
    for key in keys:
        if not isinstance(current, dict):
            return None
        current = current.get(key)
    return current


def _validate_parallel_one_shot_output_contract(
    *,
    task: str,
    args: argparse.Namespace,
    effective_algorithm_definition: dict[str, Any],
) -> None:
    ordered_sources: list[str] = []

    if task in {"predict", "audit", "encode"} and getattr(args, "ordered", False):
        ordered_sources.append("CLI --ordered")

    if task == "predict":
        if _nested_get(effective_algorithm_definition, "hotvect_execution_parameters", "predict", "ordered") is True:
            ordered_sources.append("effective algorithm definition hotvect_execution_parameters.predict.ordered=true")
    elif task == "audit":
        if _nested_get(effective_algorithm_definition, "hotvect_execution_parameters", "audit", "ordered") is True:
            ordered_sources.append("effective algorithm definition hotvect_execution_parameters.audit.ordered=true")
    elif task == "encode":
        encode_ordering = _nested_get(effective_algorithm_definition, "train_decoder_parameters", "ordering")
        if isinstance(encode_ordering, str) and encode_ordering.lower() == "ordered":
            ordered_sources.append("effective algorithm definition train_decoder_parameters.ordering='ordered'")

    if ordered_sources:
        raise ValueError(
            "Parallel SageMaker one-shot requires unordered output, but ordered output was requested via: "
            + "; ".join(ordered_sources)
        )


def _best_effort_validate_parallel_source_prefix(*, s3_client, source_s3_uri: str) -> dict[str, Any]:
    try:
        source_objects = list_source_objects(s3_client, source_s3_uri)
    except ClientError as exc:
        error = exc.response.get("Error", {})
        error_code = str(error.get("Code", ""))
        if error_code in _SOURCE_PREFLIGHT_ACCESS_DENIED_CODES:
            logger.warning(
                "Skipping parallel source-prefix validation because listing %s is not permitted (%s). "
                "SageMaker shard jobs will validate the source at runtime.",
                source_s3_uri,
                error_code,
            )
            return {"status": "skipped", "reason": "access_denied", "error_code": error_code}
        raise

    source_total_bytes = sum(source_object.size for source_object in source_objects)
    logger.info(
        "Validated parallel source prefix %s: %d usable source files, %d bytes",
        source_s3_uri,
        len(source_objects),
        source_total_bytes,
    )
    return {
        "status": "validated",
        "source_object_count": len(source_objects),
        "source_total_bytes": source_total_bytes,
    }


def _verify_parallel_one_shot_sagemaker_job(*, command_name: str, args: argparse.Namespace) -> None:
    if not getattr(args, "sagemaker", False):
        raise ValueError("--verify requires --sagemaker")
    if getattr(args, "job_parallelism", 1) not in (None, 1):
        logger.info("--job-parallelism is ignored in --verify mode")
    _require_s3_dest_path(getattr(args, "dest_path", None))
    if not getattr(args, "s3_output_base", None):
        raise ValueError("--s3-output-base is required for --verify")

    session = create_session(getattr(args, "assume_role_arn", None))
    s3_client = session.client("s3")
    sagemaker_client = session.client("sagemaker")
    manifest = load_parallel_manifest_for_dest(
        s3_client=s3_client,
        dest_path=args.dest_path,
        s3_output_base=args.s3_output_base,
    )
    submission_state = load_parallel_submission_state_for_dest(
        s3_client=s3_client,
        dest_path=args.dest_path,
        s3_output_base=args.s3_output_base,
    )
    result = verify_parallel_manifest(
        s3_client=s3_client,
        sagemaker_client=sagemaker_client,
        manifest=manifest,
        submission_state=submission_state,
        write_success=True,
    )
    put_json_to_s3(s3_client, managed_status_uri(args.s3_output_base, manifest["run_id"]), result)
    if result["complete"]:
        logger.info("Parallel one-shot verification succeeded. Wrote %s", result["success_marker_uri"])
        return
    if result["unsubmitted_shards"]:
        raise ValueError(
            "Parallel one-shot run was not fully submitted. Missing training-job names for shards: "
            + ", ".join(str(index) for index in result["unsubmitted_shards"])
        )
    if result["failed_jobs"]:
        raise ValueError(
            "Parallel one-shot run failed for jobs: "
            + ", ".join(result["failed_jobs"])
        )
    raise ValueError(
        "Parallel one-shot run is not complete yet. Running jobs: "
        + ", ".join(result["running_jobs"])
    )


def _run_parallel_one_shot_sagemaker_job(
    *,
    task: str,
    task_kind_short: str,
    command_name: str,
    args: argparse.Namespace,
) -> None:
    _require_s3_dest_path(getattr(args, "dest_path", None))
    if not getattr(args, "s3_output_base", None):
        raise ValueError("--s3-output-base is required for parallel SageMaker one-shot execution")
    if not getattr(args, "source_s3_uri", None):
        raise ValueError("--source-s3-uri is required for parallel SageMaker one-shot execution")
    if not getattr(args, "sagemaker_job_prefix", None):
        raise ValueError("--sagemaker-job-prefix is required for parallel SageMaker one-shot execution")
    if getattr(args, "job_parallelism", 1) <= 1:
        raise ValueError("--job-parallelism must be > 1 for parallel SageMaker one-shot execution")

    compression = getattr(args, "compression", "none")
    verify_command = _parallel_verify_command(command_name, args)
    source_s3_uri = normalize_s3_prefix_uri(args.source_s3_uri)
    effective_algorithm_definition = build_one_shot_effective_algorithm_definition(
        algorithm_jar=str(args.algorithm_jar),
        algorithm_name=args.algorithm_name,
        algorithm_override=getattr(args, "algorithm_override", None),
        task=task,
        parameter_s3_uri=getattr(args, "parameter_s3_uri", None),
    )
    _validate_parallel_one_shot_output_contract(
        task=task,
        args=args,
        effective_algorithm_definition=effective_algorithm_definition,
    )
    session = create_session(getattr(args, "assume_role_arn", None))
    s3_client = session.client("s3")
    validate_parallel_dest_path_is_empty(s3_client=s3_client, dest_path=args.dest_path)
    source_preflight = _best_effort_validate_parallel_source_prefix(
        s3_client=s3_client,
        source_s3_uri=source_s3_uri,
    )

    run_id = generate_runid()
    shard_plans = build_parallel_worker_plans(
        source_s3_uri=source_s3_uri,
        task=task,
        dest_path=args.dest_path,
        compression=compression,
        job_parallelism=int(args.job_parallelism),
    )
    shared_algorithm_jar_s3_uri = f"{args.s3_output_base.rstrip('/')}/_parallel_oneshot_runs/{run_id}/{Path(args.algorithm_jar).name}"
    logger.info("Uploading algorithm jar once for all shard jobs to %s", shared_algorithm_jar_s3_uri)
    parsed = urlparse(shared_algorithm_jar_s3_uri)
    if parsed.scheme != "s3" or not parsed.netloc:
        raise ValueError(f"Expected s3:// URI, got {shared_algorithm_jar_s3_uri!r}")
    s3_client.upload_file(
        Filename=str(args.algorithm_jar),
        Bucket=parsed.netloc,
        Key=parsed.path.lstrip("/"),
    )
    manifest_uri = managed_manifest_uri(args.s3_output_base, run_id)
    submission_state_uri = managed_submission_state_uri(args.s3_output_base, run_id)
    manifest = build_parallel_manifest(
        run_id=run_id,
        task=task,
        source_s3_uri=source_s3_uri,
        dest_path=args.dest_path,
        s3_output_base=args.s3_output_base,
        compression=compression,
        job_parallelism_requested=int(args.job_parallelism),
        shards=shard_plans,
        verify_command=verify_command,
    )
    manifest["source_preflight"] = source_preflight
    submission_state = build_parallel_submission_state(
        run_id=run_id,
        task=task,
        dest_path=args.dest_path,
        shards=shard_plans,
    )
    put_json_to_s3(s3_client, manifest_uri, manifest)
    put_json_to_s3(s3_client, submission_state_uri, submission_state)
    put_json_to_s3(
        s3_client,
        parallel_submission_pointer_uri(args.dest_path),
        build_submission_pointer(
            task=task,
            run_id=run_id,
            manifest_s3_uri=manifest_uri,
            submission_state_s3_uri=submission_state_uri,
            dest_path=args.dest_path,
        ),
    )
    put_json_to_s3(
        s3_client,
        managed_status_uri(args.s3_output_base, run_id),
        {
            "status": "submitting",
            "run_id": run_id,
            "task": task,
            "updated_at": datetime.now(timezone.utc).isoformat(),
        },
    )

    for shard_plan in shard_plans:
        shard_args = copy.deepcopy(args)
        shard_args.source_s3_uri = source_s3_uri
        shard_args.parallel_task_output_s3_uri = args.dest_path
        shard_args.parallel_worker_count = int(args.job_parallelism)
        shard_args.parallel_worker_index = shard_plan.index
        if task in {"predict", "audit"}:
            shard_args.ordered = False
            shard_args.unordered = True
        shard_args.parallel_preuploaded_algorithm_jar_s3_uri = shared_algorithm_jar_s3_uri
        submission = _submit_one_shot_sagemaker_job(
            task=task,
            task_kind_short=_parallel_kind_short(task_kind_short, shard_plan.index),
            args=shard_args,
        )
        shard_plan.training_job_name = submission["training_job_name"]
        shard_plan.s3_uri_result_file = submission.get("s3_uri_result_file")
        shard_plan.s3_uri_metadata = submission.get("s3_uri_metadata")
        shard_plan.task_output_s3_uri = submission.get("task_output_s3_uri")
        shard_plan.sagemaker_output_s3_path = submission.get("sagemaker_output_s3_path")
        shard_plan.hyperparameter_slug = submission.get("hyperparameter_slug")
        submission_state = build_parallel_submission_state(
            run_id=run_id,
            task=task,
            dest_path=args.dest_path,
            shards=shard_plans,
        )
        put_json_to_s3(s3_client, submission_state_uri, submission_state)

    logger.info("Parallel one-shot mode active: submitted %s shard jobs.", len(shard_plans))
    logger.info("Final part-file outputs will be written directly under: %s", args.dest_path)
    logger.info("Managed manifests/status live under: %s", args.s3_output_base)
    logger.info("If this local process is interrupted, the remote SageMaker jobs continue running.")
    logger.info("To finalize the run later and write _SUCCESS, use:\n%s", verify_command)

    status_uri = managed_status_uri(args.s3_output_base, run_id)
    if getattr(args, "no_wait", False):
        put_json_to_s3(
            s3_client,
            status_uri,
            {"status": "submitted", "run_id": run_id, "task": task, "updated_at": datetime.now(timezone.utc).isoformat()},
        )
        logger.info("--no-wait was set, so the command is exiting after submission.")
        return

    logger.info("Waiting for all shard jobs to finish. Press Ctrl-C to stop waiting; later run:\n%s", verify_command)
    sagemaker_client = session.client("sagemaker")
    try:
        result = wait_for_parallel_manifest(
            s3_client=s3_client,
            sagemaker_client=sagemaker_client,
            manifest=manifest,
            submission_state=submission_state,
            status_s3_uri=status_uri,
        )
    except KeyboardInterrupt:
        logger.warning("Local process interrupted. Remote SageMaker jobs keep running.")
        logger.warning("Run the following later to verify/finalize and write _SUCCESS:\n%s", verify_command)
        raise

    if result["complete"]:
        logger.info("Parallel one-shot run completed successfully. Wrote %s", result["success_marker_uri"])
        return
    if result["unsubmitted_shards"]:
        raise ValueError(
            "Parallel one-shot run was not fully submitted. Missing training-job names for shards: "
            + ", ".join(str(index) for index in result["unsubmitted_shards"])
        )
    raise ValueError(
        "Parallel one-shot run did not complete successfully. Failed jobs: "
        + ", ".join(result["failed_jobs"])
    )


class _HotvectVersionAction(argparse.Action):
    def __call__(
        self,
        parser: argparse.ArgumentParser,
        namespace: argparse.Namespace,
        values: object,
        option_string: str | None = None,
    ) -> None:
        message = f"hotvect (python): {hotvect.__version__}, hotvect (jar): {_get_hotvect_jar_version()}\n"
        parser.exit(message=message)


def _require_for_template_free(value: str | None, flag: str) -> str:
    if not value:
        raise ValueError(f"Missing required flag for template-free SageMaker mode: {flag}")
    return value


def _add_or_keep_source_channel(
    training_job_definition: dict[str, Any],
    *,
    source_s3_uri: str,
    channel_name: str = "source",
) -> None:
    source_s3_uri = normalize_s3_prefix_uri(source_s3_uri)
    input_data_config = training_job_definition.setdefault("InputDataConfig", [])
    if not isinstance(input_data_config, list):
        raise ValueError("InputDataConfig must be a list in SageMaker config.")
    for channel in input_data_config:
        if not isinstance(channel, dict) or channel.get("ChannelName") != channel_name:
            continue
        data_source = channel.setdefault("DataSource", {})
        if not isinstance(data_source, dict):
            raise ValueError(f"Existing SageMaker input channel {channel_name!r} has invalid DataSource")
        s3_data_source = data_source.setdefault("S3DataSource", {})
        if not isinstance(s3_data_source, dict):
            raise ValueError(f"Existing SageMaker input channel {channel_name!r} has invalid S3DataSource")
        s3_data_source["S3DataType"] = "S3Prefix"
        s3_data_source["S3Uri"] = source_s3_uri
        if "InputMode" not in channel:
            channel["InputMode"] = training_job_definition.get("AlgorithmSpecification", {}).get(
                "TrainingInputMode"
            ) or "FastFile"
        return
    training_input_mode = (
        training_job_definition.get("AlgorithmSpecification", {}).get("TrainingInputMode") or "FastFile"
    )
    input_data_config.append(
        {
            "ChannelName": channel_name,
            "DataSource": {"S3DataSource": {"S3DataType": "S3Prefix", "S3Uri": source_s3_uri}},
            "InputMode": training_input_mode,
        }
    )


def _submit_one_shot_sagemaker_job(
    *,
    task: str,
    task_kind_short: str,
    args: argparse.Namespace,
) -> dict[str, Any]:
    from hotvect.evaluation import evaluation
    from hotvect.pyhotvect import AlgorithmPipeline, AlgorithmPipelineContext

    if not args.sagemaker_job_prefix:
        raise ValueError("--sagemaker-job-prefix is required for --sagemaker")
    if not args.source_s3_uri:
        raise ValueError("--source-s3-uri is required for --sagemaker")

    with TemporaryDirectory() as tmpd:
        tmp = Path(tmpd)
        ctx = AlgorithmPipelineContext(
            algorithm_jar_path=Path(args.algorithm_jar),
            data_base_path=tmp / "data",
            metadata_base_path=tmp / "meta",
            output_base_path=tmp / "out",
            state_source_base_path=tmp / "state",
            jvm_options=[],
        )
        effective_algorithm_definition = build_one_shot_effective_algorithm_definition(
            algorithm_jar=str(args.algorithm_jar),
            algorithm_name=args.algorithm_name,
            algorithm_override=getattr(args, "algorithm_override", None),
            task=task,
            parameter_s3_uri=getattr(args, "parameter_s3_uri", None),
        )
        pipeline = AlgorithmPipeline(
            algorithm_pipeline_context=ctx,
            algorithm_definition=effective_algorithm_definition,
            last_test_time=date.today(),
            evaluation_func=evaluation.standard_evaluation,
            parameter_version="oneshot",
        )

        training_job_name = build_one_shot_training_job_name(
            prefix=args.sagemaker_job_prefix,
            jar_path=Path(args.algorithm_jar),
            hyperparameter_version=(pipeline.algorithm_definition.get("hyperparameter_version", "") or ""),
            kind=task_kind_short,
        )

        template_source = resolve_template_path(args.sagemaker_config)
        template_job_def = None
        if template_source.path:
            template_job_def = json.loads(Path(template_source.path).read_text())

        template_free = template_job_def is None
        role_arn = args.role_arn if template_free else args.role_arn
        s3_output_base = args.s3_output_base
        instance_type = args.instance_type
        if template_free:
            _require_for_template_free(role_arn, "--role-arn")
            _require_for_template_free(s3_output_base, "--s3-output-base")
            _require_for_template_free(instance_type, "--instance-type")

        training_image = resolve_training_image(
            cli_training_image=getattr(args, "training_image", None),
            algorithm_definition=pipeline.algorithm_definition,
            template_job_def=template_job_def,
        )

        job_def = build_training_job_definition(
            template_job_def=template_job_def,
            training_job_name=training_job_name,
            role_arn=role_arn,
            s3_output_base=s3_output_base,
            instance_type=instance_type,
            volume_gb=args.volume_gb,
            max_runtime_seconds=args.max_runtime_seconds,
            training_image=training_image,
        )

        algorithm_job_overrides = pipeline.algorithm_definition.get("sagemaker_training_job_definition")
        if algorithm_job_overrides:
            from hotvect.backtest import apply_sagemaker_job_overrides

            logger.info("Applying algorithm-declared SageMaker job overrides")
            apply_sagemaker_job_overrides(job_def, algorithm_job_overrides)

        legacy_params_override = None
        if pipeline.algorithm_definition.get("sagemaker_execution_parameters"):
            from hotvect.backtest import (
                apply_sagemaker_job_overrides,
                legacy_sagemaker_params_to_overrides,
            )

            legacy_params_override = legacy_sagemaker_params_to_overrides(
                pipeline.algorithm_definition.get("sagemaker_execution_parameters")
            )
        if legacy_params_override:
            logger.warning(
                "Algorithm %s uses deprecated sagemaker_execution_parameters. "
                "Please move these settings into sagemaker_training_job_definition.ResourceConfig/StoppingCondition.",
                args.algorithm_name,
            )
            apply_sagemaker_job_overrides(job_def, legacy_params_override)

        apply_cli_sagemaker_job_overrides(
            job_def,
            role_arn=role_arn,
            s3_output_base=s3_output_base,
            instance_type=instance_type,
            volume_gb=args.volume_gb,
            max_runtime_seconds=args.max_runtime_seconds,
            training_image=getattr(args, "training_image", None),
        )

        _add_or_keep_source_channel(job_def, source_s3_uri=args.source_s3_uri, channel_name="source")

        hp = job_def.setdefault("HyperParameters", {})
        parallel_task_output_s3_uri = getattr(args, "parallel_task_output_s3_uri", None)
        # Derive S3 base for this job for outputs. Executor uses: S3OutputPath + TrainingJobName
        output_s3_base = job_def["OutputDataConfig"]["S3OutputPath"].rstrip("/")
        sagemaker_job_output_prefix = f"{output_s3_base}/{training_job_name}"
        parallel_worker_count = getattr(args, "parallel_worker_count", None)
        parallel_worker_index = getattr(args, "parallel_worker_index", None)
        compression = getattr(args, "compression", "none")
        task_output_s3_uri = (
            str(parallel_task_output_s3_uri)
            if parallel_task_output_s3_uri is not None
            else f"{sagemaker_job_output_prefix}/{pipeline.hyperparameter_slug()}/{task_kind_short}"
        )
        ordered = bool(getattr(args, "ordered", False))
        unordered = bool(getattr(args, "unordered", False))
        writer_num_shards = getattr(args, "writer_num_shards", None)

        if task in {"predict", "audit"} and parallel_task_output_s3_uri is not None:
            # Parallel one-shot owns the public part-file layout, so the inner task always writes
            # unordered worker-local outputs. writer_num_shards remains per-worker fan-out.
            ordered = False
            unordered = True
        elif task == "encode" and parallel_task_output_s3_uri is None and not ordered and not unordered:
            # Single-job encode should mirror the local CLI's ordered output contract.
            ordered = True

        one_shot_hp = OneShotSagemakerHyperparameters(
            task=task,
            task_output=TaskOutputConfig(s3_uri=task_output_s3_uri, compression=compression),
            source_s3_uri=(normalize_s3_prefix_uri(args.source_s3_uri) if task == "performance-test" else None),
            algorithm_jar_s3_uri=(
                str(args.parallel_preuploaded_algorithm_jar_s3_uri)
                if getattr(args, "parallel_preuploaded_algorithm_jar_s3_uri", None)
                else None
            ),
            parameter_zip_s3_uri=getattr(args, "parameter_s3_uri", None),
            instance_type=(job_def.get("ResourceConfig", {}).get("InstanceType") if task == "performance-test" else None),
            training_image=(
                job_def.get("AlgorithmSpecification", {}).get("TrainingImage") if task == "performance-test" else None
            ),
            sagemaker_output_s3_uri=sagemaker_job_output_prefix if task == "performance-test" else None,
            ordered=ordered,
            unordered=unordered,
            writer_num_shards=writer_num_shards,
            include_feature_store_responses=bool(getattr(args, "include_feature_store_responses", False)),
            max_threads=getattr(args, "max_threads", None),
            log_features=bool(getattr(args, "log_features", False)),
            samples=getattr(args, "samples", None),
            sample_pool_size=(getattr(args, "sample_pool_size", None) if task == "performance-test" else None),
            target_rps=(getattr(args, "target_rps", None) if task == "performance-test" else None),
            target_throughput_fraction=(
                getattr(args, "target_throughput_fraction", None) if task == "performance-test" else None
            ),
            workload_mode=(getattr(args, "workload_mode", None) if task == "performance-test" else None),
            parallel_execution=(
                ParallelExecutionConfig(
                    worker_count=int(parallel_worker_count),
                    worker_index=int(parallel_worker_index),
                )
                if parallel_task_output_s3_uri is not None
                else None
            ),
        )
        hp.update(one_shot_hp.to_hyperparameters())

        try:
            from hotvect.sagemaker import SagemakerTrainingExecutor
        except ImportError as e:
            raise ImportError(
                "SageMaker support is not installed (missing optional dependency 'sagemaker_training'). "
                "Install the SageMaker extra for hotvect to use sagemaker execution."
            ) from e

        executor = SagemakerTrainingExecutor(
            algorithm_pipeline=pipeline,
            training_job_definition=job_def,
            role_arn_to_assume=args.assume_role_arn,
        )
        submission_response = executor.run()
        logger.info("SageMaker job submitted: %s", executor.training_job_name)
        logger.info("s3_uri_result_file: %s", executor.hyperparameters.get("s3_uri_result_file"))
        logger.info("s3_uri_metadata: %s", executor.hyperparameters.get("s3_uri_metadata"))
        logger.info("task_output_s3_uri: %s", task_output_s3_uri)

        if hasattr(executor, "build_submission_manifest"):
            submission_manifest = executor.build_submission_manifest(submission_response)
            submission_manifest.setdefault("s3_uri_result_file", executor.hyperparameters.get("s3_uri_result_file"))
            submission_manifest.setdefault("s3_uri_metadata", executor.hyperparameters.get("s3_uri_metadata"))
            submission_manifest.setdefault("task_output_s3_uri", task_output_s3_uri)
            return submission_manifest
        return {
            "training_job_name": executor.training_job_name,
            "submission_status": "submitted",
            "s3_uri_result_file": executor.hyperparameters.get("s3_uri_result_file"),
            "s3_uri_metadata": executor.hyperparameters.get("s3_uri_metadata"),
            "task_output_s3_uri": task_output_s3_uri,
        }


class BaseCommand(ABC):
    """Base class for all hv commands."""

    @abstractmethod
    def get_name(self) -> str:
        """Return the command name."""
        pass

    @abstractmethod
    def get_help(self) -> str:
        """Return the short help message."""
        pass

    @abstractmethod
    def get_description(self) -> str:
        """Return the detailed description."""
        pass

    @abstractmethod
    def add_arguments(self, parser: argparse.ArgumentParser) -> None:
        """Add command-specific arguments to the parser."""
        pass

    @abstractmethod
    def execute(self, args: argparse.Namespace) -> None:
        """Execute the command with parsed arguments."""
        pass

    def supports_passthrough_args(self) -> bool:
        """Whether the command accepts explicit tail args after `--`."""
        return False


def _docs_target_to_uri(target: str, *, base_uri: str = "hotvect://docs") -> str:
    normalized = (target or "").strip()
    if not normalized:
        raise ValueError("docs target must be non-empty")
    if normalized.startswith(base_uri + "/"):
        return normalized

    relpath = normalized.lstrip("/").replace("\\", "/")
    if not relpath:
        raise ValueError(f"docs target must include a path below {base_uri}/")
    if ".." in Path(relpath).parts:
        raise ValueError(f"Invalid docs target path: {target}")
    return f"{base_uri}/{relpath}"


class DocsCommand(BaseCommand):
    def get_name(self) -> str:
        return "docs"

    def get_help(self) -> str:
        return "Search and read bundled Hotvect docs (JSON output only)"

    def get_description(self) -> str:
        return (
            "Search and read the bundled Hotvect documentation corpus. Output is always JSON on stdout. "
            "By default hv docs uses scan-based search and avoids local SQLite index writes."
        )

    def add_arguments(self, parser: argparse.ArgumentParser) -> None:
        parser.add_argument(
            "--sqlite-index",
            action=argparse.BooleanOptionalAction,
            default=None,
            help=(
                "Enable SQLite FTS indexing for faster repeated searches. Disabled by default to avoid local cache writes; "
                "use --sqlite-index-path to pin the cache file location."
            ),
        )
        parser.add_argument(
            "--sqlite-index-path",
            default=None,
            help="Optional explicit path for the SQLite docs index file (implies --sqlite-index).",
        )

        subparsers = parser.add_subparsers(dest="docs_command", required=True, metavar="<docs-command>")

        subparsers.add_parser("list", help="List bundled docs")

        search_parser = subparsers.add_parser("search", help="Search bundled docs")
        search_parser.add_argument("query", nargs="+", help="Search query")
        search_parser.add_argument("--limit", type=int, default=20, help="Maximum results to return (default: 20)")

        read_parser = subparsers.add_parser("read", help="Read one bundled doc")
        read_parser.add_argument(
            "target",
            help="Document URI (hotvect://docs/...) or docs-relative path (for example reference/cli/index.md)",
        )

    def execute(self, args: argparse.Namespace) -> None:
        from hotvect.mcp.docs_repo import DocsRepository, bundled_docs_traversable

        if args.sqlite_index is False and args.sqlite_index_path:
            _exit_cli_usage_error("--sqlite-index-path cannot be used with --no-sqlite-index")

        sqlite_index = bool(args.sqlite_index) if args.sqlite_index is not None else bool(args.sqlite_index_path)
        sqlite_index_path = Path(args.sqlite_index_path).expanduser() if args.sqlite_index_path else None

        docs = bundled_docs_traversable()
        with as_file(docs) as docs_root:
            repo = DocsRepository(
                docs_root=Path(docs_root).resolve(),
                sqlite_index=sqlite_index,
                sqlite_index_path=sqlite_index_path,
                hotvect_version=getattr(hotvect, "__version__", "unknown"),
            )

            if args.docs_command == "list":
                payload = {"docs": repo.list_docs()}
            elif args.docs_command == "search":
                payload = repo.search(" ".join(args.query), limit=args.limit)
            elif args.docs_command == "read":
                try:
                    payload = repo.read_markdown(_docs_target_to_uri(args.target))
                except (FileNotFoundError, ValueError) as e:
                    _exit_cli_usage_error(str(e))
            else:
                _exit_cli_usage_error(f"Unknown docs command: {args.docs_command}")

        print(json.dumps(payload, indent=2))


class PromptsCommand(BaseCommand):
    def get_name(self) -> str:
        return "prompts"

    def get_help(self) -> str:
        return "List and read bundled Hotvect prompt templates (JSON output only)"

    def get_description(self) -> str:
        return (
            "List and read the bundled Hotvect prompt templates that are also exposed by hv-mcp. "
            "Output is always JSON on stdout."
        )

    def add_arguments(self, parser: argparse.ArgumentParser) -> None:
        subparsers = parser.add_subparsers(dest="prompts_command", required=True, metavar="<prompts-command>")

        subparsers.add_parser("list", help="List bundled prompt templates")

        read_parser = subparsers.add_parser("read", help="Read one bundled prompt template")
        read_parser.add_argument("name", help="Prompt name (for example setup_config)")

    def execute(self, args: argparse.Namespace) -> None:
        from hotvect.mcp.prompts import get_prompt, list_prompts

        if args.prompts_command == "list":
            payload = {"prompts": list_prompts()}
        elif args.prompts_command == "read":
            try:
                prompt = get_prompt(args.name)
            except ValueError as e:
                _exit_cli_usage_error(str(e))
            payload = {
                "name": prompt.name,
                "description": prompt.description,
                "text": prompt.text,
            }
        else:
            _exit_cli_usage_error(f"Unknown prompts command: {args.prompts_command}")

        print(json.dumps(payload, indent=2))


def add_sagemaker_args(
    parser: argparse.ArgumentParser,
    *,
    job_prefix_required_with_config: bool,
    training_image_help: str,
    include_source_s3_uri: bool = False,
    source_s3_uri_help: str = "S3 prefix for the input data (one-shot SageMaker mode)",
    include_parameter_s3_uri: bool = False,
    parameter_s3_uri_help: str = (
        "S3 URI to parameters zip (optional for encode/predict, required for audit/perf-test SageMaker mode)"
    ),
    include_parallel_args: bool = False,
) -> None:
    """Add the shared SageMaker CLI surface used by train/backtest and one-shot commands."""

    job_prefix_help = (
        "Required when using --sagemaker or --sagemaker-config. Must be a valid SageMaker TrainingJobName prefix."
        if job_prefix_required_with_config
        else "Required when using --sagemaker. Must be a valid SageMaker TrainingJobName prefix."
    )

    parser.add_argument("--sagemaker", action="store_true", help="Execute this command remotely on SageMaker")
    parser.add_argument("--sagemaker-job-prefix", help=job_prefix_help)
    parser.add_argument("--sagemaker-config", help="Path to JSON file containing SageMaker training job configuration")
    parser.add_argument(
        "--role-arn",
        help="SageMaker job execution role ARN (CreateTrainingJob.RoleArn). Required in template-free mode.",
    )
    parser.add_argument(
        "--assume-role-arn",
        help="AWS role ARN to assume for SageMaker submission (optional; defaults to using current AWS credentials)",
    )
    parser.add_argument("--s3-output-base", help="S3 output base prefix used in template-free mode (OutputDataConfig.S3OutputPath)")
    parser.add_argument(
        "--instance-type",
        help=(
            "Primary SageMaker instance type used in template-free mode (ResourceConfig.InstanceType). "
            "For ordered capacity fallback, set HotvectSubmissionOptions.PreferredInstanceTypes in the "
            "job definition."
        ),
    )
    parser.add_argument("--volume-gb", type=int, help="EBS volume size in GB (ResourceConfig.VolumeSizeInGB)")
    parser.add_argument("--max-runtime-seconds", type=int, help="Max runtime in seconds (StoppingCondition.MaxRuntimeInSeconds)")
    parser.add_argument("--training-image", dest="training_image", help=training_image_help)

    if include_source_s3_uri:
        parser.add_argument("--source-s3-uri", help=source_s3_uri_help)
    if include_parameter_s3_uri:
        parser.add_argument("--parameter-s3-uri", help=parameter_s3_uri_help)
    if include_parallel_args:
        parser.add_argument(
            "--job-parallelism",
            type=int,
            default=1,
            help="Parallelize one-shot SageMaker runs across N shard jobs (SageMaker-only, optional)",
        )
        parser.add_argument(
            "--verify",
            action="store_true",
            help="Verify/finalize a previously submitted parallel one-shot SageMaker run and write _SUCCESS",
        )
        parser.add_argument(
            "--no-wait",
            action="store_true",
            help=(
                "Submit a SageMaker one-shot run and exit after submission. "
                "For parallel runs this skips waiting/finalization; for single-job runs this is a no-op convenience flag."
            ),
        )


def add_output_ordering_args(parser: argparse.ArgumentParser, *, command_label: str) -> None:
    parser.add_argument(
        "--ordered",
        action="store_true",
        help=f"Whether {command_label} output should strictly follow the order of the input (optional)",
    )
    parser.add_argument(
        "--unordered",
        action="store_true",
        help=f"Allow unordered internal {command_label} processing and write part files under --dest-path (optional)",
    )
    parser.add_argument(
        "--writer-num-shards",
        type=int,
        help=f"Number of unordered {command_label} output part files (<=0 auto-determines count, optional)",
    )


def validate_output_ordering_flags(args: argparse.Namespace) -> None:
    if bool(getattr(args, "ordered", False)) and bool(getattr(args, "unordered", False)):
        raise ValueError("At most one of --ordered and --unordered may be specified")
    writer_num_shards = getattr(args, "writer_num_shards", None)
    if bool(getattr(args, "ordered", False)) and writer_num_shards is not None and writer_num_shards > 1:
        raise ValueError(
            "--writer-num-shards > 1 may only be used with --unordered. Ordered output always writes a single part file."
        )


def resolve_local_output_ordering(command_name: str, args: argparse.Namespace) -> tuple[bool, bool]:
    ordered = bool(getattr(args, "ordered", False))
    unordered = bool(getattr(args, "unordered", False))
    if command_name == "encode" and not ordered and not unordered:
        ordered = True
    return ordered, unordered


class JavaCommand(BaseCommand):
    """Base class for commands that execute Java with hotvect JAR."""

    def supports_passthrough_args(self) -> bool:
        return True

    def add_arguments(self, parser: argparse.ArgumentParser) -> None:
        """Add common Java command arguments."""
        parser.add_argument("--algorithm-jar",
                          help="Path to the JAR file containing the algorithm implementation")
        parser.add_argument("--algorithm-name", type=_parse_algorithm_name,
                          help="Name of the algorithm to execute")
        parser.add_argument(
            "--algorithm-override",
            help=(
                f"{_ALGORITHM_OVERRIDE_HELP} "
                "When set, hv loads the base algorithm definition from the JAR, merges overrides, "
                "writes a complete effective definition to --metadata-path/effective_algorithm_definition.json, and passes that "
                "JSON file to Java."
            ),
        )
        parser.add_argument("--metadata-path",
                          help="Directory where metadata.json and log files will be written (optional, auto-generated if not specified)")

        # Add source-path with default settings, subclasses can override
        source_required, source_help = self.get_source_path_config()
        parser.add_argument(
            "--source-path",
            required=False,
            help=source_help + (" (required for local execution)" if source_required else ""),
        )

        parser.add_argument("--dest-path",
                          help="Path where the operation results will be saved (optional, auto-generated if not specified)")
        parser.add_argument("--parameter-path",
                          help="Path to the trained model parameter file (optional for encode/predict, required for audit/performance-test/serve/worker serve)")
        parser.add_argument("--dest-schema-path",
                          help="Path where the feature schema description will be saved (optional, used in encoding operations)")
        parser.add_argument("--samples", type=int,
                          help="Number of samples to process, useful for testing with smaller datasets (optional)")
        parser.add_argument(
            "--max-threads",
            type=int,
            default=None,
            help=(
                "Max worker threads for Hotvect Java execution. "
                "For performance-test, if omitted hv defaults to 2 threads on machines with >=4 physical cores "
                "(else 1); pass an explicit value to override, or 0 to let the JAR decide. (optional)"
            ),
        )
        add_sagemaker_args(
            parser,
            job_prefix_required_with_config=False,
            training_image_help="Training image URI (AlgorithmSpecification.TrainingImage)",
            include_source_s3_uri=True,
            include_parameter_s3_uri=True,
            include_parallel_args=True,
        )
        # Add command-specific arguments
        self.add_command_arguments(parser)

    def _resolve_java_algorithm_definition_arg(self, args: argparse.Namespace) -> str:
        """
        Return the value to pass to Java's `--algorithm-definition`.

        - Without `--algorithm-override`: use the algorithm name so Java reads the definition from the algorithm JAR.
        - With `--algorithm-override`: write a complete "effective" algorithm definition JSON file and pass its path.
        """
        if not getattr(args, "algorithm_override", None):
            return args.algorithm_name
        effective_def = serialize_effective_algorithm_definition(
            _load_effective_algorithm_definition(
                str(args.algorithm_jar),
                args.algorithm_name,
                getattr(args, "algorithm_override", None),
            )
        )

        metadata_dir = Path(args.metadata_path)
        effective_def_path = metadata_dir / "effective_algorithm_definition.json"
        effective_def_path.parent.mkdir(parents=True, exist_ok=True)
        with open(effective_def_path, "w", encoding="utf-8") as f:
            json.dump(effective_def, f, indent=2, sort_keys=True)
            f.write("\n")

        logger.info("Wrote effective algorithm definition to: %s", effective_def_path)
        return str(effective_def_path)

    def get_source_path_config(self):
        """Return (required, help_text) for --source-path argument. Override in subclasses."""
        return False, "Path to the input data source for the operation (optional for some commands)"

    def add_command_arguments(self, parser: argparse.ArgumentParser) -> None:
        """Override to add command-specific arguments."""
        pass

    def execute(self, args: argparse.Namespace) -> None:
        """Execute Java command with common logic."""
        command_name = self.get_name()
        parallel_requested = getattr(args, "job_parallelism", 1) > 1
        verify_requested = bool(getattr(args, "verify", False))

        if command_name in {"predict", "audit", "encode"}:
            validate_output_ordering_flags(args)
        if verify_requested:
            if not getattr(args, "sagemaker", False):
                raise ValueError("--verify requires --sagemaker")
            if getattr(args, "no_wait", False):
                raise ValueError("--no-wait cannot be combined with --verify")
            if command_name not in {"audit", "predict", "encode"}:
                raise ValueError(f"--verify is not supported for '{command_name}'")
            _verify_parallel_one_shot_sagemaker_job(command_name=command_name, args=args)
            return
        if getattr(args, "no_wait", False) and not getattr(args, "sagemaker", False):
            raise ValueError("--no-wait is only supported with --sagemaker")
        if getattr(args, "compression", "none") != "none":
            if command_name == "encode":
                raise ValueError("--compression is not supported for encode")
            if command_name not in {"predict", "audit"}:
                raise ValueError("--compression is only supported for predict and audit")
            if not parallel_requested:
                raise ValueError("--compression is only supported for parallel one-shot SageMaker runs")
        if parallel_requested:
            if not getattr(args, "sagemaker", False):
                raise ValueError("--job-parallelism is only supported with --sagemaker")
            if command_name not in {"audit", "predict", "encode"}:
                raise ValueError(f"--job-parallelism is not supported for '{command_name}'")
            if command_name in {"predict", "audit", "encode"} and getattr(args, "ordered", False):
                raise ValueError("--ordered is not supported together with --job-parallelism")
            if getattr(args, "algorithm_jar", None) is None:
                raise ValueError("--algorithm-jar is required")
            if getattr(args, "algorithm_name", None) is None:
                raise ValueError("--algorithm-name is required")
            _run_parallel_one_shot_sagemaker_job(
                task=command_name,
                task_kind_short=command_name,
                command_name=command_name,
                args=args,
            )
            return
        # SageMaker mode: submit one-shot job and return immediately.
        if getattr(args, "sagemaker", False):
            if command_name not in {"audit", "predict", "encode", "performance-test"}:
                raise ValueError(f"--sagemaker is not supported for '{command_name}'")
            if getattr(args, "algorithm_jar", None) is None:
                raise ValueError("--algorithm-jar is required")
            if getattr(args, "algorithm_name", None) is None:
                raise ValueError("--algorithm-name is required")
            task = command_name
            kind_short = "perf" if command_name == "performance-test" else command_name
            if task == "performance-test":
                task = "performance-test"
                kind_short = "perf"
            if task in {"audit", "performance-test"} and not getattr(args, "parameter_s3_uri", None):
                raise ValueError("--parameter-s3-uri is required for this command in --sagemaker mode")
            _submit_one_shot_sagemaker_job(task=task, task_kind_short=kind_short, args=args)
            if getattr(args, "no_wait", False):
                logger.info(
                    "--no-wait was set. Single-job SageMaker one-shot runs already return after submission, so no "
                    "additional waiting or finalization is performed."
                )
            return

        # Set default paths if not provided
        if not getattr(args, 'metadata_path', None):
            metadata_dir = f"{args.algorithm_name}.{command_name}.metadata"
            logger.info(f"Metadata path not provided. Using default directory: {metadata_dir}")
            args.metadata_path = metadata_dir
        if str(args.metadata_path).endswith(".json"):
            print(
                "Error: --metadata-path now expects a directory, not a .json file. Example: --metadata-path myrun.metadata",
                file=sys.stderr,
            )
            sys.exit(2)
        Path(args.metadata_path).mkdir(parents=True, exist_ok=True)
        _enable_file_logging(Path(args.metadata_path))

        needs_dest_path = command_name in {"encode", "predict", "audit", "generate-state"}
        if needs_dest_path and not getattr(args, 'dest_path', None):
            dest_path = f"{args.algorithm_name}.{command_name}.output"
            logger.info(f"Destination path not provided. Using default: {dest_path}")
            args.dest_path = dest_path

        if command_name == "encode" and not getattr(args, 'dest_schema_path', None):
            dest_schema_path = f"{args.algorithm_name}.{command_name}.output.schema"
            logger.info(f"Destination schema path not provided. Using default: {dest_schema_path}")
            args.dest_schema_path = dest_schema_path

        source_required, _ = self.get_source_path_config()
        if getattr(args, "algorithm_jar", None) is None:
            raise ValueError("--algorithm-jar is required")
        if getattr(args, "algorithm_name", None) is None:
            raise ValueError("--algorithm-name is required")
        if source_required and not getattr(args, "source_path", None):
            raise ValueError("--source-path is required for local execution")

        # Get JVM args that were passed after the command
        jvm_args = getattr(args, '_jvm_args', [])

        self.run_java_command(args, jvm_args)

    def run_java_command(self, args: argparse.Namespace, jvm_args: list[str]) -> None:
        """Run the Java command."""

        cmd = ["java"]
        normalized_jvm_args = normalize_runtime_jvm_args(jvm_args)
        cmd.extend(normalized_jvm_args)
        if "-cp" not in normalized_jvm_args:
            cmd.extend(["-cp", str(_hotvectjar_module().HOTVECT_JAR_PATH)])

        algorithm_definition_arg = self._resolve_java_algorithm_definition_arg(args)
        subcommand = self.get_name()
        ordered, unordered = resolve_local_output_ordering(subcommand, args)
        spec = OfflineTaskSpec(
            task=subcommand,
            algorithm_jar_path=Path(args.algorithm_jar),
            algorithm_definition_arg=algorithm_definition_arg,
            metadata_path=Path(args.metadata_path),
            source_path=Path(args.source_path) if getattr(args, "source_path", None) else None,
            dest_path=Path(args.dest_path) if getattr(args, "dest_path", None) else None,
            parameter_path=Path(args.parameter_path) if getattr(args, "parameter_path", None) else None,
            dest_schema_description_path=(
                Path(args.dest_schema_path) if getattr(args, "dest_schema_path", None) else None
            ),
            samples=getattr(args, "samples", None),
            sample_pool_size=getattr(args, "sample_pool_size", None),
            max_threads=getattr(args, "max_threads", None),
            ordered=ordered,
            unordered=unordered,
            writer_num_shards=getattr(args, "writer_num_shards", None),
            include_feature_store_responses=bool(getattr(args, "include_feature_store_responses", False)),
            target_rps=getattr(args, "target_rps", None),
            target_throughput_fraction=getattr(args, "target_throughput_fraction", None),
            workload_mode=getattr(args, "workload_mode", None),
            log_features=bool(getattr(args, "log_features", False)),
        )
        cmd.extend(build_offline_task_main_args(spec))

        cmd_str = ' '.join(map(str, cmd))
        logger.info(f"Running command: {cmd_str}")
        _tee_subprocess_output_to_metadata_dir(cmd, Path(args.metadata_path))


class AuditCommand(JavaCommand):
    def get_name(self) -> str:
        return "audit"

    def get_help(self) -> str:
        return "Generate human-readable audit data showing feature transformations and calculations"

    def get_description(self) -> str:
        return "Perform feature transformation on input data and save results as human-readable JSONL format. This is useful for debugging algorithms, inspecting calculated features, and understanding how input data is transformed by the feature engineering pipeline."

    def get_source_path_config(self):
        return True, "Path to the input data source for auditing (required)"

    def add_command_arguments(self, parser: argparse.ArgumentParser) -> None:
        parser.add_argument(
            "--compression",
            choices=("none", "gzip"),
            default="none",
            help="Compression for parallel audit part-file outputs (default: none)",
        )
        add_output_ordering_args(parser, command_label="audit")
        parser.add_argument(
            "--include-feature-store-responses",
            action="store_true",
            help="Include feature store responses in audit output under additional_properties.__feature_store_responses (optional)",
        )


class PerformanceTestCommand(JavaCommand):
    def get_name(self) -> str:
        return "performance-test"

    def get_help(self) -> str:
        return "Benchmark algorithm performance and measure throughput/latency"

    def get_description(self) -> str:
        return "Execute performance benchmarks on the specified algorithm to measure prediction throughput, latency, and resource utilization. Results help optimize algorithm performance and identify bottlenecks."

    def get_source_path_config(self):
        return True, "Path to the input data source for the performance test (required)"

    def add_command_arguments(self, parser: argparse.ArgumentParser) -> None:
        parser.add_argument(
            "--target-rps",
            type=float,
            default=None,
            help="Performance-test only: target requests/sec. Overrides --target-throughput-fraction.",
        )
        parser.add_argument(
            "--target-throughput-fraction",
            type=float,
            default=None,
            help=(
                "Performance-test only: fraction of warmup mean throughput to use as target requests/sec when "
                "--target-rps is not set. Default is 0.8. 0 disables pacing."
            ),
        )
        parser.add_argument(
            "--workload-mode",
            choices=("realtime", "batch"),
            default=None,
            help=(
                "Performance-test only: execution workload mode. Default is realtime because performance-test "
                "normally measures serving latency. Use batch to explicitly benchmark the batch path."
            ),
        )
        parser.add_argument(
            "--sample-pool-size",
            type=int,
            default=None,
            help=(
                "Performance-test only: number of decoded candidate examples retained in memory for replay. "
                "This is separate from --samples, which controls measured executions."
            ),
        )

    def run_java_command(self, args: argparse.Namespace, jvm_args: list[str]) -> None:
        if getattr(args, "max_threads", None) is None:
            import os

            import psutil

            physical_cores = psutil.cpu_count(logical=False) or os.cpu_count() or 1
            args.max_threads = 2 if physical_cores >= 4 else 1
            logger.info("performance-test defaulting to --max-threads %s (physical cores=%s)", args.max_threads, physical_cores)
        super().run_java_command(args, jvm_args)


