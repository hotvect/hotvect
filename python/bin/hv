#!/usr/bin/env python3
import argparse
import copy
import json
import logging
import math
import os
import shlex
import sys
import zipfile
from abc import ABC, abstractmethod
from datetime import date
from pathlib import Path
from tempfile import TemporaryDirectory
from typing import Any, Dict, List, Optional, Tuple, Union

import hotvect
import hotvect.hotvectjar
from hotvect.sagemaker_config import (
    apply_performance_test_samples_override,
    build_training_job_definition,
    resolve_template_path,
    resolve_training_image,
    validate_job_prefix,
)
from hotvect.sagemaker_job_name import build_one_shot_training_job_name

_LOG_FORMAT = "%(asctime)s:%(levelname)s:%(name)s:%(funcName)s:%(message)s"

logging.basicConfig(
    level=logging.INFO,
    stream=sys.stdout,
    format=_LOG_FORMAT
)
logger = logging.getLogger(__name__)

_DEFAULT_HV_LOG_FILENAME = "hv.log"
_DEFAULT_STDOUT_STDERR_LOG_FILENAME = "stdout-stderr.log"


def _enable_file_logging(log_dir: Path) -> None:
    log_dir.mkdir(parents=True, exist_ok=True)
    log_path = (log_dir / _DEFAULT_HV_LOG_FILENAME).resolve()
    root_logger = logging.getLogger()
    for handler in root_logger.handlers:
        if isinstance(handler, logging.FileHandler) and Path(handler.baseFilename).resolve() == log_path:
            return

    file_handler = logging.FileHandler(log_path, mode="a", encoding="utf-8")
    file_handler.setLevel(logging.INFO)
    file_handler.setFormatter(logging.Formatter(_LOG_FORMAT))
    root_logger.addHandler(file_handler)
    logger.info("Python logs: %s", log_path)


def _tee_subprocess_output_to_metadata_dir(
    cmd: list[str],
    metadata_dir: Path,
    env: dict[str, str] | None = None,
) -> None:
    from hotvect.utils import stream_output

    metadata_dir.mkdir(parents=True, exist_ok=True)
    stdout_stderr_log_path = (metadata_dir / _DEFAULT_STDOUT_STDERR_LOG_FILENAME).resolve()
    with open(stdout_stderr_log_path, "a", encoding="utf-8") as fp:
        def _display(chunk: str) -> None:
            sys.stdout.write(chunk)
            fp.write(chunk)
            fp.flush()

        stream_output(cmd, _display, env=env)


def _parse_algorithm_name(value: str) -> str:
    """
    Parse and validate `--algorithm-name`.

    hv intentionally only accepts an algorithm name here (not an algorithm-definition JSON path).
    To pass a full algorithm definition JSON, use `--algorithm-override`.
    """
    lowered = value.lower()
    if lowered.endswith(".json") or "/" in value or "\\" in value:
        raise argparse.ArgumentTypeError(
            f"--algorithm-name must be an algorithm name (not a file path): {value}. "
            f"Use --algorithm-override to pass algorithm definition JSON."
        )

    from hotvect.utils import verify_algorithm_name

    try:
        return verify_algorithm_name(value)
    except ValueError as e:
        raise argparse.ArgumentTypeError(str(e)) from e


def _get_hotvect_jar_version() -> str:
    jar_path = hotvect.hotvectjar.HOTVECT_JAR_PATH
    pom_properties_path = "META-INF/maven/com.hotvect/hotvect-offline-util/pom.properties"
    with zipfile.ZipFile(jar_path) as jar:
        contents = jar.read(pom_properties_path).decode("utf-8")

    for line in contents.splitlines():
        key, sep, value = line.partition("=")
        if sep and key.strip() == "version":
            return value.strip()

    raise ValueError(f"Expected 'version=' in {pom_properties_path} inside {jar_path}")


class _HotvectVersionAction(argparse.Action):
    def __call__(
        self,
        parser: argparse.ArgumentParser,
        namespace: argparse.Namespace,
        values: object,
        option_string: str | None = None,
    ) -> None:
        message = f"hotvect (python): {hotvect.__version__}, hotvect (jar): {_get_hotvect_jar_version()}\n"
        parser.exit(message=message)


def _require_for_template_free(value: Optional[str], flag: str) -> str:
    if not value:
        raise ValueError(f"Missing required flag for template-free SageMaker mode: {flag}")
    return value


def _add_or_keep_source_channel(
    training_job_definition: Dict[str, Any],
    *,
    source_s3_uri: str,
    channel_name: str = "source",
) -> None:
    input_data_config = training_job_definition.setdefault("InputDataConfig", [])
    if not isinstance(input_data_config, list):
        raise ValueError("InputDataConfig must be a list in SageMaker config.")
    if any(isinstance(ch, dict) and ch.get("ChannelName") == channel_name for ch in input_data_config):
        return
    training_input_mode = (
        training_job_definition.get("AlgorithmSpecification", {}).get("TrainingInputMode") or "FastFile"
    )
    input_data_config.append(
        {
            "ChannelName": channel_name,
            "DataSource": {"S3DataSource": {"S3DataType": "S3Prefix", "S3Uri": source_s3_uri}},
            "InputMode": training_input_mode,
        }
    )


def _submit_one_shot_sagemaker_job(
    *,
    task: str,
    task_kind_short: str,
    args: argparse.Namespace,
) -> None:
    from hotvect.pyhotvect import AlgorithmPipeline, AlgorithmPipelineContext

    import hotvect.mlutils as mlutils

    if not args.sagemaker_job_prefix:
        raise ValueError("--sagemaker-job-prefix is required for --sagemaker")
    if not args.source_s3_uri:
        raise ValueError("--source-s3-uri is required for --sagemaker")

    with TemporaryDirectory() as tmpd:
        tmp = Path(tmpd)
        ctx = AlgorithmPipelineContext(
            algorithm_jar_path=Path(args.algorithm_jar),
            data_base_path=tmp / "data",
            metadata_base_path=tmp / "meta",
            output_base_path=tmp / "out",
            state_source_base_path=tmp / "state",
            jvm_options=[],
        )
        algorithm_definition_arg: Union[str, Tuple[str, Dict[str, Any]]] = args.algorithm_name
        needs_effective_definition = bool(getattr(args, "algorithm_override", None)) or (
            task in {"predict", "audit", "performance-test"} and getattr(args, "parameter_s3_uri", None)
        )
        if needs_effective_definition:
            effective_algorithm_definition = _load_effective_algorithm_definition(
                str(args.algorithm_jar),
                args.algorithm_name,
                getattr(args, "algorithm_override", None),
            )
            effective_algorithm_definition = _pin_with_parameter_for_one_shot_task(
                effective_algorithm_definition,
                task=task,
                parameter_s3_uri=getattr(args, "parameter_s3_uri", None),
            )
            algorithm_definition_arg = (args.algorithm_name, effective_algorithm_definition)
        pipeline = AlgorithmPipeline(
            algorithm_pipeline_context=ctx,
            algorithm_definition=algorithm_definition_arg,
            last_test_time=date.today(),
            evaluation_func=mlutils.standard_evaluation,
            parameter_version="oneshot",
        )

        training_job_name = build_one_shot_training_job_name(
            prefix=args.sagemaker_job_prefix,
            jar_path=Path(args.algorithm_jar),
            hyperparameter_version=(pipeline.algorithm_definition.get("hyperparameter_version", "") or ""),
            kind=task_kind_short,
        )

        template_source = resolve_template_path(args.sagemaker_config)
        template_job_def = None
        if template_source.path:
            template_job_def = json.loads(Path(template_source.path).read_text())

        template_free = template_job_def is None
        role_arn = args.role_arn if template_free else args.role_arn
        s3_output_base = args.s3_output_base
        instance_type = args.instance_type
        if template_free:
            _require_for_template_free(role_arn, "--role-arn")
            _require_for_template_free(s3_output_base, "--s3-output-base")
            _require_for_template_free(instance_type, "--instance-type")

        training_image = resolve_training_image(
            cli_training_image=getattr(args, "training_image", None),
            algorithm_definition=pipeline.algorithm_definition,
            template_job_def=template_job_def,
        )

        job_def = build_training_job_definition(
            template_job_def=template_job_def,
            training_job_name=training_job_name,
            role_arn=role_arn,
            s3_output_base=s3_output_base,
            instance_type=instance_type,
            volume_gb=args.volume_gb,
            max_runtime_seconds=args.max_runtime_seconds,
            training_image=training_image,
        )

        _add_or_keep_source_channel(job_def, source_s3_uri=args.source_s3_uri, channel_name="source")

        hp = job_def.setdefault("HyperParameters", {})
        hp["hotvect_task"] = task
        hp["hotvect_source_channel"] = "source"
        if getattr(args, "parameter_s3_uri", None):
            hp["s3_uri_parameter_zip"] = args.parameter_s3_uri
        if getattr(args, "include_feature_store_responses", None):
            hp["hotvect_include_feature_store_responses"] = "true"
        if getattr(args, "samples", None) is not None:
            hp["hotvect_samples"] = str(args.samples)
        if task == "performance-test" and getattr(args, "target_rps", None) is not None:
            hp["hotvect_target_rps"] = str(args.target_rps)
        if task == "performance-test" and getattr(args, "target_throughput_fraction", None) is not None:
            hp["hotvect_target_throughput_fraction"] = str(args.target_throughput_fraction)
        if task == "performance-test" and getattr(args, "workload_mode", None) is not None:
            hp["hotvect_workload_mode"] = str(args.workload_mode)

        # Derive S3 base for this job for outputs. Executor uses: S3OutputPath + TrainingJobName
        output_s3_base = job_def["OutputDataConfig"]["S3OutputPath"].rstrip("/")
        sagemaker_job_output_prefix = f"{output_s3_base}/{training_job_name}"
        hp["s3_uri_task_output"] = f"{sagemaker_job_output_prefix}/{pipeline.hyperparameter_slug()}/{task_kind_short}"

        try:
            from hotvect.sagemaker import SagemakerTrainingExecutor
        except ImportError as e:
            raise ImportError(
                "SageMaker support is not installed (missing optional dependency 'sagemaker_training'). "
                "Install the SageMaker extra for hotvect to use sagemaker execution."
            ) from e

        executor = SagemakerTrainingExecutor(
            algorithm_pipeline=pipeline,
            training_job_definition=job_def,
            role_arn_to_assume=args.assume_role_arn,
        )
        executor.run()

        logger.info("SageMaker job submitted: %s", executor.training_job_name)
        logger.info("s3_uri_result_file: %s", executor.hyperparameters.get("s3_uri_result_file"))
        logger.info("s3_uri_metadata: %s", executor.hyperparameters.get("s3_uri_metadata"))
        logger.info("s3_uri_task_output: %s", hp.get("s3_uri_task_output"))


class BaseCommand(ABC):
    """Base class for all hv commands."""

    @abstractmethod
    def get_name(self) -> str:
        """Return the command name."""
        pass

    @abstractmethod
    def get_help(self) -> str:
        """Return the short help message."""
        pass

    @abstractmethod
    def get_description(self) -> str:
        """Return the detailed description."""
        pass

    @abstractmethod
    def add_arguments(self, parser: argparse.ArgumentParser) -> None:
        """Add command-specific arguments to the parser."""
        pass

    @abstractmethod
    def execute(self, args: argparse.Namespace) -> None:
        """Execute the command with parsed arguments."""
        pass

    def supports_passthrough_args(self) -> bool:
        """Whether the command accepts explicit tail args after `--`."""
        return False


class JavaCommand(BaseCommand):
    """Base class for commands that execute Java with hotvect JAR."""

    def supports_passthrough_args(self) -> bool:
        return True

    def add_arguments(self, parser: argparse.ArgumentParser) -> None:
        """Add common Java command arguments."""
        parser.add_argument("--algorithm-jar", required=True,
                          help="Path to the JAR file containing the algorithm implementation (required)")
        parser.add_argument("--algorithm-name", required=True, type=_parse_algorithm_name,
                          help="Name of the algorithm to execute (required)")
        parser.add_argument(
            "--algorithm-override",
            help=(
                "Path to JSON file containing algorithm configuration overrides (optional). "
                "When set, hv loads the base algorithm definition from the JAR, merges overrides, "
                "writes a complete effective definition to --metadata-path/effective_algorithm_definition.json, and passes that "
                "JSON file to Java."
            ),
        )
        parser.add_argument("--metadata-path",
                          help="Directory where metadata.json and log files will be written (optional, auto-generated if not specified)")

        # Add source-path with default settings, subclasses can override
        source_required, source_help = self.get_source_path_config()
        parser.add_argument(
            "--source-path",
            required=False,
            help=source_help + (" (required for local execution)" if source_required else ""),
        )

        parser.add_argument("--dest-path",
                          help="Path where the operation results will be saved (optional, auto-generated if not specified)")
        parser.add_argument("--parameter-path",
                          help="Path to the trained model parameter file (required for predict/audit/serve/worker serve, optional for others)")
        parser.add_argument("--dest-schema-path",
                          help="Path where the feature schema description will be saved (optional, used in encoding operations)")
        parser.add_argument("--samples", type=int,
                          help="Number of samples to process, useful for testing with smaller datasets (optional)")
        parser.add_argument(
            "--max-threads",
            type=int,
            default=None,
            help=(
                "Max worker threads for Hotvect Java execution. "
                "For performance-test, if omitted hv defaults to 2 threads on machines with >=4 physical cores "
                "(else 1); pass an explicit value to override, or 0 to let the JAR decide. (optional)"
            ),
        )

        # SageMaker execution (one-shot)
        parser.add_argument("--sagemaker", action="store_true", help="Execute this command remotely on SageMaker")
        parser.add_argument(
            "--sagemaker-job-prefix",
            help="Required when using --sagemaker. Must be a valid SageMaker TrainingJobName prefix.",
        )
        parser.add_argument("--sagemaker-config", help="Path to JSON file containing SageMaker training job configuration")
        parser.add_argument(
            "--role-arn",
            help="SageMaker job execution role ARN (CreateTrainingJob.RoleArn). Required in template-free mode.",
        )
        parser.add_argument(
            "--assume-role-arn",
            help="AWS role ARN to assume for SageMaker submission (optional; defaults to using current AWS credentials)",
        )
        parser.add_argument("--s3-output-base", help="S3 output base prefix used in template-free mode (OutputDataConfig.S3OutputPath)")
        parser.add_argument("--instance-type", help="SageMaker instance type used in template-free mode (ResourceConfig.InstanceType)")
        parser.add_argument("--volume-gb", type=int, help="EBS volume size in GB (ResourceConfig.VolumeSizeInGB)")
        parser.add_argument("--max-runtime-seconds", type=int, help="Max runtime in seconds (StoppingCondition.MaxRuntimeInSeconds)")
        parser.add_argument("--training-image", dest="training_image", help="Training image URI (AlgorithmSpecification.TrainingImage)")
        parser.add_argument("--source-s3-uri", help="S3 prefix for the input data (one-shot SageMaker mode)")
        parser.add_argument("--parameter-s3-uri", help="S3 URI to parameters zip (predict/audit/perf-test SageMaker mode)")

        # Add command-specific arguments
        self.add_command_arguments(parser)

    def _resolve_java_algorithm_definition_arg(self, args: argparse.Namespace) -> str:
        """
        Return the value to pass to Java's `--algorithm-definition`.

        - Without `--algorithm-override`: use the algorithm name so Java reads the definition from the algorithm JAR.
        - With `--algorithm-override`: write a complete "effective" algorithm definition JSON file and pass its path.
        """
        if not getattr(args, "algorithm_override", None):
            return args.algorithm_name

        from hotvect.utils import read_algorithm_definition_from_jar, recursive_dict_update

        base_def = read_algorithm_definition_from_jar(args.algorithm_name, Path(args.algorithm_jar))

        with open(args.algorithm_override, "r", encoding="utf-8") as f:
            override = json.load(f)
        if not isinstance(override, dict):
            raise ValueError(
                f"--algorithm-override must be a JSON object, got {type(override).__name__}: {args.algorithm_override}"
            )

        if "algorithm_name" in override and override["algorithm_name"] != args.algorithm_name:
            raise ValueError(
                f"--algorithm-override may not change algorithm_name (expected {args.algorithm_name}, got {override['algorithm_name']})"
            )

        effective_def = copy.deepcopy(base_def)
        recursive_dict_update(effective_def, override)
        if effective_def.get("algorithm_name") != args.algorithm_name:
            raise ValueError(
                f"--algorithm-override changed algorithm_name to {effective_def.get('algorithm_name')}; this is not supported"
            )

        metadata_dir = Path(args.metadata_path)
        effective_def_path = metadata_dir / "effective_algorithm_definition.json"
        effective_def_path.parent.mkdir(parents=True, exist_ok=True)
        with open(effective_def_path, "w", encoding="utf-8") as f:
            json.dump(effective_def, f, indent=2, sort_keys=True)
            f.write("\n")

        logger.info("Wrote effective algorithm definition to: %s", effective_def_path)
        return str(effective_def_path)

    def get_source_path_config(self):
        """Return (required, help_text) for --source-path argument. Override in subclasses."""
        return False, "Path to the input data source for the operation (optional for some commands)"

    def add_command_arguments(self, parser: argparse.ArgumentParser) -> None:
        """Override to add command-specific arguments."""
        pass

    def execute(self, args: argparse.Namespace) -> None:
        """Execute Java command with common logic."""
        command_name = self.get_name()

        # SageMaker mode: submit one-shot job and return immediately.
        if getattr(args, "sagemaker", False):
            if command_name not in {"audit", "predict", "encode", "performance-test"}:
                raise ValueError(f"--sagemaker is not supported for '{command_name}'")
            task = command_name
            kind_short = "perf" if command_name == "performance-test" else command_name
            if task == "performance-test":
                task = "performance-test"
                kind_short = "perf"
            if task in {"predict", "audit", "performance-test"} and not getattr(args, "parameter_s3_uri", None):
                raise ValueError("--parameter-s3-uri is required for this command in --sagemaker mode")
            _submit_one_shot_sagemaker_job(task=task, task_kind_short=kind_short, args=args)
            return

        # Set default paths if not provided
        if not getattr(args, 'metadata_path', None):
            metadata_dir = f"{args.algorithm_name}.{command_name}.metadata"
            logger.info(f"Metadata path not provided. Using default directory: {metadata_dir}")
            args.metadata_path = metadata_dir
        if str(args.metadata_path).endswith(".json"):
            print(
                "Error: --metadata-path now expects a directory, not a .json file. Example: --metadata-path myrun.metadata",
                file=sys.stderr,
            )
            sys.exit(2)
        Path(args.metadata_path).mkdir(parents=True, exist_ok=True)
        _enable_file_logging(Path(args.metadata_path))

        needs_dest_path = command_name in {"encode", "predict", "audit", "generate-state", "list-transformations"}
        if needs_dest_path and not getattr(args, 'dest_path', None):
            dest_path = f"{args.algorithm_name}.{command_name}.output"
            logger.info(f"Destination path not provided. Using default: {dest_path}")
            args.dest_path = dest_path

        if command_name == "encode" and not getattr(args, 'dest_schema_path', None):
            dest_schema_path = f"{args.algorithm_name}.{command_name}.output.schema"
            logger.info(f"Destination schema path not provided. Using default: {dest_schema_path}")
            args.dest_schema_path = dest_schema_path

        source_required, _ = self.get_source_path_config()
        if source_required and not getattr(args, "source_path", None):
            raise ValueError("--source-path is required for local execution")

        # Get JVM args that were passed after the command
        jvm_args = getattr(args, '_jvm_args', [])

        self.run_java_command(args, jvm_args)

    def run_java_command(self, args: argparse.Namespace, jvm_args: List[str]) -> None:
        """Run the Java command."""

        cmd = ["java"]
        cmd.extend(jvm_args)
        if not any(arg.startswith("-Xmx") or arg.startswith("-XX:MaxRAMPercentage") for arg in jvm_args):
            cmd.append("-XX:MaxRAMPercentage=90")
        if "-XX:+ExitOnOutOfMemoryError" not in jvm_args:
            cmd.append("-XX:+ExitOnOutOfMemoryError")
        if "-cp" not in jvm_args:
            cmd.extend(["-cp", str(hotvect.hotvectjar.HOTVECT_JAR_PATH)])

        algorithm_definition_arg = self._resolve_java_algorithm_definition_arg(args)
        subcommand = self.get_name()
        cmd.extend(
            [
                "com.hotvect.offlineutils.commandline.Main",
                subcommand,
                "--algorithm-jar",
                str(args.algorithm_jar),
                "--algorithm-definition",
                algorithm_definition_arg,
                "--metadata-path",
                str(args.metadata_path),
            ]
        )

        tasks_with_dest = {"encode", "predict", "audit", "generate-state", "list-transformations"}
        tasks_with_source = {"encode", "predict", "audit", "performance-test", "generate-state"}
        tasks_with_parameters = {"encode", "predict", "audit", "performance-test", "list-transformations"}
        tasks_with_samples = {"encode", "predict", "audit", "performance-test"}
        tasks_with_max_threads = {"encode", "predict", "audit", "performance-test"}

        if subcommand in tasks_with_dest:
            cmd.extend(["--dest", str(args.dest_path)])

        if getattr(args, "max_threads", None) and args.max_threads > 0 and subcommand in tasks_with_max_threads:
            cmd.extend(["--max-threads", str(args.max_threads)])

        if args.source_path and subcommand in tasks_with_source:
            cmd.extend(["--source", str(args.source_path)])

        if subcommand == "encode":
            cmd.append("--ordered")

        if subcommand == "encode":
            cmd.extend(["--dest-schema-description", str(args.dest_schema_path)])

        if getattr(args, "parameter_path", None) and subcommand in tasks_with_parameters:
            cmd.extend(["--parameters", str(args.parameter_path)])

        if getattr(args, "samples", None) is not None and subcommand in tasks_with_samples:
            cmd.extend(["--samples", str(args.samples)])

        if subcommand == "performance-test" and getattr(args, "target_rps", None) is not None:
            cmd.extend(["--target-rps", str(args.target_rps)])

        if subcommand == "performance-test" and getattr(args, "target_throughput_fraction", None) is not None:
            cmd.extend(["--target-throughput-fraction", str(args.target_throughput_fraction)])

        if subcommand == "performance-test" and getattr(args, "workload_mode", None) is not None:
            cmd.extend(["--workload-mode", str(args.workload_mode)])

        if subcommand == "predict" and getattr(args, "log_features", None):
            cmd.append("--log-features")

        if subcommand in {"predict", "audit"} and getattr(args, "include_feature_store_responses", None):
            cmd.append("--include-feature-store-responses")

        if subcommand == "list-transformations" and getattr(args, "verbose", None):
            cmd.append("--verbose")

        cmd_str = ' '.join(map(str, cmd))
        logger.info(f"Running command: {cmd_str}")
        _tee_subprocess_output_to_metadata_dir(cmd, Path(args.metadata_path))


class AuditCommand(JavaCommand):
    def get_name(self) -> str:
        return "audit"

    def get_help(self) -> str:
        return "Generate human-readable audit data showing feature transformations and calculations"

    def get_description(self) -> str:
        return "Perform feature transformation on input data and save results as human-readable JSONL format. This is useful for debugging algorithms, inspecting calculated features, and understanding how input data is transformed by the feature engineering pipeline."

    def get_source_path_config(self):
        return True, "Path to the input data source for auditing (required)"

    def add_command_arguments(self, parser: argparse.ArgumentParser) -> None:
        parser.add_argument(
            "--include-feature-store-responses",
            action="store_true",
            help="Include feature store responses in audit output under additional_properties.__feature_store_responses (optional)",
        )


class PerformanceTestCommand(JavaCommand):
    def get_name(self) -> str:
        return "performance-test"

    def get_help(self) -> str:
        return "Benchmark algorithm performance and measure throughput/latency"

    def get_description(self) -> str:
        return "Execute performance benchmarks on the specified algorithm to measure prediction throughput, latency, and resource utilization. Results help optimize algorithm performance and identify bottlenecks."

    def get_source_path_config(self):
        return True, "Path to the input data source for the performance test (required)"

    def add_command_arguments(self, parser: argparse.ArgumentParser) -> None:
        parser.add_argument(
            "--target-rps",
            type=float,
            default=None,
            help="Performance-test only: target requests/sec. Overrides --target-throughput-fraction.",
        )
        parser.add_argument(
            "--target-throughput-fraction",
            type=float,
            default=None,
            help=(
                "Performance-test only: fraction of warmup mean throughput to use as target requests/sec when "
                "--target-rps is not set. Default is 0.8. 0 disables pacing."
            ),
        )
        parser.add_argument(
            "--workload-mode",
            choices=("realtime", "batch"),
            default=None,
            help=(
                "Performance-test only: execution workload mode. Default is realtime because performance-test "
                "normally measures serving latency. Use batch to explicitly benchmark the batch path."
            ),
        )

    def run_java_command(self, args: argparse.Namespace, jvm_args: List[str]) -> None:
        if getattr(args, "max_threads", None) is None:
            import os

            import psutil

            physical_cores = psutil.cpu_count(logical=False) or os.cpu_count() or 1
            args.max_threads = 2 if physical_cores >= 4 else 1
            logger.info("performance-test defaulting to --max-threads %s (physical cores=%s)", args.max_threads, physical_cores)
        super().run_java_command(args, jvm_args)


