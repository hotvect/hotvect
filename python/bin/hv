    def get_name(self) -> str:
        return "evaluate"

    def get_help(self) -> str:
        return "Calculate performance metrics from model predictions"

    def get_description(self) -> str:
        return "Compute evaluation metrics (accuracy, precision, recall, AUC, etc.) from prediction results. Can perform both online/offline analysis to compare model performance across different scenarios and data splits."

    def add_arguments(self, parser: argparse.ArgumentParser) -> None:
        parser.add_argument("--source-path", required=True,
                          help="Path to the prediction results file (JSONL format) to evaluate (required)")
        parser.add_argument("--dest-path", required=True,
                          help="Path where the evaluation metrics will be saved as JSON (required)")
        parser.add_argument("--enable-online-offline-analysis", action='store_true',
                          help="Enable detailed online vs offline performance analysis (optional)")

    def execute(self, args: argparse.Namespace) -> None:
        from hotvect.mlutils import standard_evaluation

        perform_online_offline_evaluations = args.enable_online_offline_analysis
        result = standard_evaluation(path=args.source_path)
        with open(args.dest_path, 'w') as f:
            json.dump(result, f, indent=2)
        print(f"Evaluation results saved to {args.dest_path}")


class TrainCommand(BaseCommand):
    def get_name(self) -> str:
        return "train"

    def get_help(self) -> str:
        return "Train a machine learning model using the hotvect pipeline"

    def get_description(self) -> str:
        return "Train a machine learning model using the hotvect pipeline with specified algorithm and data paths"

    def add_arguments(self, parser: argparse.ArgumentParser) -> None:
        parser.add_argument("--algorithm-name", required=True, type=_parse_algorithm_name,
                          help="Name of the algorithm to train (required)")
        parser.add_argument("--data-base-dir", default="",
                          help="Base directory containing training data (default: from ~/.hotvect/config.json)")
        parser.add_argument("--output-base-dir", default="",
                          help="Base directory where training outputs will be saved (default: from ~/.hotvect/config.json)")
        parser.add_argument("--algorithm-jar", required=True,
                          help="Path to the JAR file containing the algorithm implementation (required)")
        parser.add_argument("--last-test-time", required=True,
                          help="Last test time in YYYY-MM-DD format, e.g., '2025-04-30' (required)")
        parser.add_argument("--algorithm-override",
                          help="Path to JSON file containing algorithm configuration overrides (optional)")
        parser.add_argument("--extra-jvm-args",
                          help="Additional JVM arguments for training, comma-separated, e.g., '-Xmx64g,-XX:+UseG1GC' (optional)")
        parser.add_argument("--max-threads", type=int, default=0,
                          help="Max threads for hotvect encode/predict. 0=don't pass; JAR decides. (optional)")
        parser.add_argument(
            "--cache",
            dest="cache_base_dir",
            default=None,
            help="Enable Hotvect pipeline caching (local path or s3://example-bucket).",
        )
        parser.add_argument(
            "--cache-scope",
            choices=["major", "minor", "patch", "hyperparam"],
            default="hyperparam",
            help=(
                "Cache key scope across algorithm versions. "
                "major=X.*, minor=X.Y.*, patch=X.Y.Z, hyperparam=X.Y.Z[-hyperparameter_version] (default: hyperparam)."
            ),
        )
        parser.add_argument(
            "--cache-refresh",
            action="store_true",
            help="Ignore cache reads (force recompute) while still writing results to cache.",
        )

        parser.add_argument("--sagemaker", action="store_true", help="Execute this training remotely on SageMaker")
        parser.add_argument(
            "--sagemaker-job-prefix",
            help="Required when using --sagemaker or --sagemaker-config. Must be a valid SageMaker TrainingJobName prefix.",
        )
        parser.add_argument("--sagemaker-config", help="Path to JSON file containing SageMaker training job configuration (optional)")
        parser.add_argument("--role-arn", help="SageMaker job execution role ARN (CreateTrainingJob.RoleArn) (optional)")
        parser.add_argument(
            "--assume-role-arn",
            help="AWS role ARN to assume for SageMaker submission (optional; defaults to using current AWS credentials)",
        )
        parser.add_argument("--s3-output-base", help="S3 output base prefix used in template-free SageMaker mode (OutputDataConfig.S3OutputPath)")
        parser.add_argument("--instance-type", help="SageMaker instance type used in template-free SageMaker mode (ResourceConfig.InstanceType)")
        parser.add_argument("--volume-gb", type=int, help="EBS volume size in GB (ResourceConfig.VolumeSizeInGB)")
        parser.add_argument("--max-runtime-seconds", type=int, help="Max runtime in seconds (StoppingCondition.MaxRuntimeInSeconds)")
        parser.add_argument("--training-image", dest="training_image", help="Training image URI override (AlgorithmSpecification.TrainingImage)")

        parser.add_argument("--performance-test-samples", type=int, help="Pin perf-test sample size for comparability")
        parser.add_argument("--auto-attach-data", action="store_true", help="Auto-populate InputDataConfig from algorithm dependencies (SageMaker mode)")
        parser.add_argument("--auto-attach-data-default-s3-base", help="Default S3 base URI used when dependencies do not specify explicit s3_uri")
        parser.add_argument(
            "--auto-attach-data-environment",
            choices=["production", "test"],
            default="production",
            help="Environment key to use when dependency s3_uri is a map (default: production)",
        )

    def execute(self, args: argparse.Namespace) -> None:
        remote_mode = bool(args.sagemaker or args.sagemaker_config)
        from hotvect.pyhotvect import AlgorithmPipeline, AlgorithmPipelineContext
        from hotvect.utils import recursive_dict_update

        import hotvect.mlutils as mlutils

        if not remote_mode:
            cfg_dirs: Dict[str, Any] = {}
            if not args.data_base_dir or not args.output_base_dir:
                from hotvect.extra.config import try_load_config

                cfg = try_load_config() or {}
                cfg_dirs = cfg.get("directories", {}) if isinstance(cfg, dict) else {}

                if not args.data_base_dir:
                    args.data_base_dir = cfg_dirs.get("data_base_dir", "")
                if not args.output_base_dir:
                    args.output_base_dir = cfg_dirs.get("output_base_dir", "")

            if not args.data_base_dir or not args.output_base_dir:
                raise ValueError(
                    "Missing required base dirs. Provide --data-base-dir/--output-base-dir, "
                    "or set them in ~/.hotvect/config.json under config.directories."
                )

        # Parse extra JVM args if provided
        jvm_options = ["-XX:MaxRAMPercentage=90"]  # Default JVM memory
        if args.extra_jvm_args:
            extra_jvm_args = [arg.strip() for arg in args.extra_jvm_args.split(',')]
            jvm_options.extend(extra_jvm_args)

        # Parse last test time
        last_test_time = date.fromisoformat(args.last_test_time)

        # Handle algorithm definition with optional overrides
        algorithm_definition = args.algorithm_name
        if args.cache_refresh and not args.cache_base_dir:
            print("Error: --cache-refresh requires --cache.", file=sys.stderr)
            sys.exit(2)

        override_config: Optional[Dict[str, Any]] = None
        if args.algorithm_override:
            logger.info(f"Loading algorithm overrides from: {args.algorithm_override}")
            with open(args.algorithm_override, "r") as f:
                override_config = json.load(f)
            logger.info(f"Applied algorithm overrides: {override_config}")
        if args.cache_base_dir:
            cache_overrides = {
                "hotvect_execution_parameters": {
                    "cache_base_dir": args.cache_base_dir,
                    "cache_scope": args.cache_scope,
                    **({"cache_refresh": True} if args.cache_refresh else {}),
                }
            }
            override_config = recursive_dict_update(override_config or {}, cache_overrides)
        override_config = apply_performance_test_samples_override(override_config, args.performance_test_samples)
        if override_config:
            algorithm_definition = (args.algorithm_name, override_config)

        if remote_mode:
            if not args.sagemaker_job_prefix:
                raise ValueError("--sagemaker-job-prefix is required for SageMaker execution")
            validate_job_prefix(args.sagemaker_job_prefix)

            template_source = resolve_template_path(args.sagemaker_config)
            template_job_def = None
            if template_source.path:
                template_job_def = json.loads(Path(template_source.path).read_text())

            template_free = template_job_def is None
            if template_free:
                _require_for_template_free(args.role_arn, "--role-arn")
                _require_for_template_free(args.s3_output_base, "--s3-output-base")
                _require_for_template_free(args.instance_type, "--instance-type")

            with TemporaryDirectory() as tmpd:
                tmp = Path(tmpd)
                context = AlgorithmPipelineContext(
                    algorithm_jar_path=Path(args.algorithm_jar),
                    data_base_path=Path(args.data_base_dir) if args.data_base_dir else (tmp / "data"),
                    metadata_base_path=tmp / "meta",
                    output_base_path=tmp / "out",
                    state_source_base_path=tmp / "states",
                    jvm_options=jvm_options,
                    max_threads=None,
                )

                pipeline = AlgorithmPipeline(
                    algorithm_pipeline_context=context,
                    algorithm_definition=algorithm_definition,
                    last_test_time=last_test_time,
                    evaluation_func=mlutils.standard_evaluation,
                )

                training_job_name = build_one_shot_training_job_name(
                    prefix=args.sagemaker_job_prefix,
                    jar_path=Path(args.algorithm_jar),
                    hyperparameter_version=(pipeline.algorithm_definition.get("hyperparameter_version", "") or ""),
                    kind="train",
                )

                training_image = resolve_training_image(
                    cli_training_image=args.training_image,
                    algorithm_definition=pipeline.algorithm_definition,
                    template_job_def=template_job_def,
                )

                job_def = build_training_job_definition(
                    template_job_def=template_job_def,
                    training_job_name=training_job_name,
                    role_arn=args.role_arn,
                    s3_output_base=args.s3_output_base,
                    instance_type=args.instance_type,
                    volume_gb=args.volume_gb,
                    max_runtime_seconds=args.max_runtime_seconds,
                    training_image=training_image,
                    require_training_image=True,
                )

                if args.auto_attach_data:
                    from hotvect.backtest import attach_input_data_config_for_dependencies

                    attach_input_data_config_for_dependencies(
                        algorithm_pipeline=pipeline,
                        training_job_definition=job_def,
                        auto_attach_data_default_s3_base=args.auto_attach_data_default_s3_base,
                        auto_attach_data_environment=args.auto_attach_data_environment,
                    )

                try:
                    from hotvect.sagemaker import SagemakerTrainingExecutor
                except ImportError as e:
                    raise ImportError(
                        "SageMaker support is not installed (missing optional dependency 'sagemaker_training'). "
                        "Install the SageMaker extra for hotvect to use sagemaker execution."
                    ) from e

                executor = SagemakerTrainingExecutor(
                    algorithm_pipeline=pipeline,
                    training_job_definition=job_def,
                    role_arn_to_assume=args.assume_role_arn,
                )
                executor.run()
                logger.info("SageMaker job submitted: %s", executor.training_job_name)
                logger.info("s3_uri_result_file: %s", executor.hyperparameters.get("s3_uri_result_file"))
                logger.info("s3_uri_metadata: %s", executor.hyperparameters.get("s3_uri_metadata"))
                logger.info(
                    "s3_uri_predict_parameters_zip: %s", executor.hyperparameters.get("s3_uri_predict_parameters_zip")
                )
                return

        # Create the pipeline context
        if not args.data_base_dir:
            raise ValueError("--data-base-dir is required for local execution")
        context = AlgorithmPipelineContext(
            algorithm_jar_path=Path(args.algorithm_jar),
            state_source_base_path=Path(args.data_base_dir),
            data_base_path=Path(args.data_base_dir),
            metadata_base_path=Path(args.output_base_dir) / "metadata",
            output_base_path=Path(args.output_base_dir),
            jvm_options=jvm_options,
            max_threads=(args.max_threads if args.max_threads and args.max_threads > 0 else None)
        )

        logger.info(f"Starting training for algorithm: {args.algorithm_name}")
        logger.info(f"Data base directory: {args.data_base_dir}")
        logger.info(f"Output base directory: {args.output_base_dir}")
        logger.info(f"Algorithm JAR: {args.algorithm_jar}")

        # Create and run the pipeline
        pipeline = AlgorithmPipeline(
            algorithm_pipeline_context=context,
            algorithm_definition=algorithm_definition,
            last_test_time=last_test_time,
            evaluation_func=mlutils.standard_evaluation
        )
        pipeline.run_all()

        logger.info("Training pipeline completed successfully")


def _resolve_host(cli_host: Optional[str]) -> str:
    return cli_host or "127.0.0.1"


def _load_effective_algorithm_definition(
    algorithm_jar: str,
    algorithm_name: str,
    algorithm_override: Optional[str],
) -> Dict[str, Any]:
    from hotvect.utils import read_algorithm_definition_from_jar, recursive_dict_update

    effective = read_algorithm_definition_from_jar(algorithm_name, Path(algorithm_jar))
    if not algorithm_override:
        return effective

    with open(algorithm_override, "r", encoding="utf-8") as f:
        override = json.load(f)
    if not isinstance(override, dict):
        raise ValueError(
            f"--algorithm-override must be a JSON object, got {type(override).__name__}: {algorithm_override}"
        )
    if "algorithm_name" in override and override["algorithm_name"] != algorithm_name:
        raise ValueError(
            f"--algorithm-override may not change algorithm_name (expected {algorithm_name}, got {override['algorithm_name']})"
        )

    recursive_dict_update(effective, override)
    if effective.get("algorithm_name") != algorithm_name:
        raise ValueError(
            f"--algorithm-override changed algorithm_name to {effective.get('algorithm_name')}; this is not supported"
        )
    return effective


def _pin_with_parameter_for_one_shot_task(
    algorithm_definition: Dict[str, Any],
    *,
    task: str,
    parameter_s3_uri: Optional[str],
) -> Dict[str, Any]:
    if task not in {"predict", "audit", "performance-test"} or not parameter_s3_uri:
        return algorithm_definition

    existing = algorithm_definition.get("hotvect_execution_parameters", {}).get("with_parameter")
    if existing and existing != parameter_s3_uri:
        raise ValueError(
            "Conflicting with_parameter pin for one-shot task: "
            f"algorithm definition has {existing!r}, but --parameter-s3-uri is {parameter_s3_uri!r}"
        )

    algorithm_definition = copy.deepcopy(algorithm_definition)
    algorithm_definition.setdefault("hotvect_execution_parameters", {})["with_parameter"] = parameter_s3_uri
    return algorithm_definition


def _extract_model_and_schema_from_parameters(zip_path: str, algorithm_name: str, temp_dir: str) -> tuple[Path, Path]:
    import zipfile

    zip_path_obj = Path(zip_path)
    if not zip_path_obj.exists():
        raise ValueError(f"Parameter file not found: {zip_path}")

    with zipfile.ZipFile(zip_path_obj) as zf:
        prefixes = set()
        for name in zf.namelist():
            if not name.startswith(algorithm_name):
                continue
            next_char_idx = len(algorithm_name)
            if next_char_idx < len(name) and name[next_char_idx] not in ("@", "/"):
                continue
            prefixes.add(name.split("/")[0] + "/")

        if not prefixes:
            raise ValueError(f"Algorithm '{algorithm_name}' not found in parameters ZIP")
        if len(prefixes) > 1:
            raise ValueError(f"Ambiguous ZIP structure: multiple algorithm paths found: {sorted(prefixes)}")

        prefix = next(iter(prefixes))
        logger.info("Found algorithm prefix in ZIP: %s", prefix)

        model_dir = None
        schema_path = None
        temp_path = Path(temp_dir).resolve()
        for member in zf.namelist():
            if not member.startswith(prefix):
                continue
            dest_path = (temp_path / member).resolve()
            if not dest_path.is_relative_to(temp_path):
                raise ValueError(f"Unsafe ZIP entry (path traversal): {member}")
            if member.startswith(prefix + "model_parameter/"):
                zf.extract(member, temp_dir)
                if model_dir is None:
                    model_dir = temp_path / prefix / "model_parameter"
            elif member == prefix + "encoded-schema-description":
                zf.extract(member, temp_dir)
                schema_path = temp_path / prefix / "encoded-schema-description"

        if model_dir is None:
            raise ValueError(f"Parameters ZIP missing model_parameter/ for algorithm '{algorithm_name}'")
        if schema_path is None:
            raise ValueError(f"Parameters ZIP missing encoded-schema-description for algorithm '{algorithm_name}'")
        return model_dir, schema_path


def _wait_for_health(
    host: str, port: int, timeout: int = 30, request_timeout_seconds: float = 2, process=None
) -> bool:
    import time

    if request_timeout_seconds <= 0:
        raise ValueError(f"request_timeout_seconds must be > 0, got {request_timeout_seconds}")

    import requests

    connect_host = "127.0.0.1" if host == "0.0.0.0" else host
    health_url = f"http://{connect_host}:{port}/health"
    start_time = time.time()

    while time.time() - start_time < timeout:
        if process is not None and process.poll() is not None:
            return False
        try:
            response = requests.get(health_url, timeout=request_timeout_seconds)
            if response.status_code == 200:
                return True
        except (requests.RequestException, ConnectionError, OSError):
            pass
        time.sleep(0.5)

    return False


def _run_http_server_process(
    cmd: List[str],
    *,
    host: str,
    port: int,
    health_timeout_seconds: int,
    health_request_timeout_seconds: float,
    env: Optional[Dict[str, str]] = None,
) -> None:
    import subprocess
    import threading

    logger.info("Starting server: %s", shlex.join(cmd))
    process = subprocess.Popen(cmd, env=env, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
    try:
        def _stream_output(proc=process):
            assert proc.stdout is not None
            for line in proc.stdout:
                print(line, end="")

        threading.Thread(target=_stream_output, daemon=True).start()

        healthy = _wait_for_health(
            host,
            port,
            timeout=health_timeout_seconds,
            request_timeout_seconds=health_request_timeout_seconds,
            process=process,
        )
        if not healthy and process.poll() is None:
            raise RuntimeError(
                f"Server started but health check timed out after {health_timeout_seconds}s"
            )
        if process.poll() is not None:
            raise RuntimeError(f"Server exited before becoming healthy (exit_code={process.returncode})")

        connect_host = "127.0.0.1" if host == "0.0.0.0" else host
        logger.info("Inference server running at http://%s:%s", connect_host, port)
        logger.info("Press Ctrl+C to stop")
        process.wait()
    except KeyboardInterrupt:
        logger.info("Shutting down...")
    finally:
        if process.poll() is None:
            process.terminate()
            try:
                process.wait(timeout=5)
            except subprocess.TimeoutExpired:
                process.kill()
                process.wait()


def _stringify_env_overrides(raw: Any, *, field_name: str) -> Dict[str, str]:
    if raw is None:
        return {}
    if not isinstance(raw, dict):
        raise ValueError(f"{field_name} must be an object, got {type(raw).__name__}")
    overrides = {str(k): str(v) for k, v in raw.items() if v is not None}
    if "CUDA_VISIBLE_DEVICES" in overrides:
        raise ValueError(f"{field_name} must not set CUDA_VISIBLE_DEVICES; it is derived from the selected worker runtime config")
    return overrides


def _parse_cuda_visible_devices_allowlist(visible: Optional[str]) -> List[str]:
    if visible is None:
        return []
    trimmed = visible.strip()
    if not trimmed:
        return []
    if trimmed.lower() in {"-1", "nodevfiles"}:
        return []

    seen = set()
    tokens = []
    for token in trimmed.split(","):
        t = token.strip()
        if not t or t.lower() in {"-1", "nodevfiles"}:
            continue
        if t in seen:
            raise ValueError(f"CUDA_VISIBLE_DEVICES must not contain duplicates, got: {visible}")
        seen.add(t)
        tokens.append(t)
    return tokens


def _detect_cuda_visible_device_tokens() -> List[str]:
    import subprocess

    try:
        result = subprocess.run(
            ["nvidia-smi", "-L"],
            capture_output=True,
            text=True,
            timeout=2,
            check=False,
        )
    except Exception:
        return []
    if result.returncode != 0:
        return []

    tokens = []
    seen = set()
    for line in result.stdout.splitlines():
        trimmed = line.strip()
        if not trimmed.startswith("GPU"):
            continue
        colon = trimmed.find(":")
        if colon < 0:
            continue
        prefix = trimmed[:colon].split()
        if len(prefix) < 2 or not prefix[1].isdigit():
            continue
        token = prefix[1]
        if token not in seen:
            seen.add(token)
            tokens.append(token)
    return tokens


def _select_cuda_visible_device_tokens(devices_value: Any, available_tokens: List[str]) -> List[str]:
    if not available_tokens:
        raise ValueError("No CUDA devices available")
    if devices_value is None:
        return available_tokens
    if isinstance(devices_value, str):
        if devices_value.strip().lower() == "auto":
            return available_tokens
        raise ValueError(f"devices must be an int, int array, or 'auto' when accelerator='cuda', got string: {devices_value}")
    if isinstance(devices_value, int) and not isinstance(devices_value, bool):
        count = devices_value
        if count < 1:
            raise ValueError(f"devices must be >= 1 when accelerator='cuda', got: {count}")
        if count > len(available_tokens):
            raise ValueError(f"devices is greater than available CUDA device count: requested={count} available={len(available_tokens)}")
        return available_tokens[:count]
    if isinstance(devices_value, float) and not isinstance(devices_value, bool):
        if not math.isfinite(devices_value) or not devices_value.is_integer():
            raise ValueError(f"devices numeric value must be an integer when accelerator='cuda', got: {devices_value}")
        count = int(devices_value)
        if count < 1:
            raise ValueError(f"devices must be >= 1 when accelerator='cuda', got: {count}")
        if count > len(available_tokens):
            raise ValueError(f"devices is greater than available CUDA device count: requested={count} available={len(available_tokens)}")
        return available_tokens[:count]
    if isinstance(devices_value, list):
        if not devices_value:
            raise ValueError("devices must be a non-empty list when accelerator='cuda'")
        out = []
        seen_indices = set()
        for element in devices_value:
            if not isinstance(element, int):
                raise ValueError(f"devices list must contain only integers, got: {element!r}")
            if element < 0:
                raise ValueError(f"devices values must be >= 0, got: {element}")
            if element in seen_indices:
                raise ValueError(f"devices must not contain duplicates, got: {element}")
            if element >= len(available_tokens):
                raise ValueError(
                    f"devices references a CUDA device index that is not available: index={element} available={len(available_tokens)}"
                )
            seen_indices.add(element)
            out.append(available_tokens[element])
        return out
    raise ValueError(
        f"devices must be 'auto', int, or int array, got: {type(devices_value).__name__}"
    )


def _resolve_worker_server_cuda_visible_devices(config: Dict[str, Any], parent_visible_devices: Optional[str]) -> str:
    accelerator_raw = str(config.get("accelerator", "auto")).strip().lower()
    accelerator = accelerator_raw or "auto"
    if accelerator not in {"cpu", "cuda", "gpu", "auto"}:
        raise ValueError(f"accelerator must be 'cpu', 'cuda', 'gpu', or 'auto', got: {config.get('accelerator')}")

    available_tokens = (
        _parse_cuda_visible_devices_allowlist(parent_visible_devices)
        if parent_visible_devices is not None
        else _detect_cuda_visible_device_tokens()
    )

    if accelerator == "cpu":
        return ""
    if accelerator == "auto" and not available_tokens:
        return ""
    if accelerator in {"cuda", "gpu"} and not available_tokens:
        raise ValueError(f"accelerator='{accelerator}' requested but no CUDA devices are available")

    selected_tokens = _select_cuda_visible_device_tokens(config.get("devices", "auto"), available_tokens)
    return ",".join(selected_tokens)


def _resolve_worker_server_litserve_devices_arg(config: Dict[str, Any], parent_visible_devices: Optional[str]) -> str:
    accelerator_raw = str(config.get("accelerator", "auto")).strip().lower()
    accelerator = accelerator_raw or "auto"
    if accelerator == "cpu":
        return "auto"

    available_tokens = (
        _parse_cuda_visible_devices_allowlist(parent_visible_devices)
        if parent_visible_devices is not None
        else _detect_cuda_visible_device_tokens()
    )
    if accelerator == "auto" and not available_tokens:
        return "auto"
    if accelerator in {"cuda", "gpu"} and not available_tokens:
        raise ValueError(f"accelerator='{accelerator}' requested but no CUDA devices are available")

    selected_tokens = _select_cuda_visible_device_tokens(config.get("devices", "auto"), available_tokens)
    return str(len(selected_tokens))


def _resolve_worker_backend(algorithm_definition: Dict[str, Any]) -> str:
    algo_params = algorithm_definition.get("algorithm_parameters")
    if not isinstance(algo_params, dict):
        raise ValueError("Algorithm definition is missing algorithm_parameters")

    backend = algo_params.get("backend")
    if not isinstance(backend, str) or not backend.strip():
        raise ValueError("algorithm_parameters.backend must be a non-empty string")

    return backend.strip().lower()


def _resolve_worker_backend_cfg(
    backend: str,
    algorithm_definition: Dict[str, Any],
    *,
    debug_include_tf_inputs: bool,
) -> Dict[str, Any]:
    algo_params = algorithm_definition.get("algorithm_parameters")
    if not isinstance(algo_params, dict):
        raise ValueError("Algorithm definition is missing algorithm_parameters")

    if backend == "tensorflow":
        return {
            "backend": backend,
            "debug_include_tf_inputs": debug_include_tf_inputs,
        }
    if backend == "torch":
        if debug_include_tf_inputs:
            raise ValueError("--debug-include-tf-inputs is only supported for tensorflow worker backends")
        zmclip_cfg = algo_params.get("zmclip")
        if not isinstance(zmclip_cfg, dict):
            raise ValueError("algorithm_parameters.zmclip must be an object for torch worker backend")
        model_name = zmclip_cfg.get("model_name", "xlm-roberta-base-ViT-B-32")
        if not isinstance(model_name, str) or not model_name.strip():
            raise ValueError("algorithm_parameters.zmclip.model_name must be a non-empty string when provided")
        return {
            "backend": backend,
            "torch_model_name": model_name.strip(),
            "use_torch_compile": bool(zmclip_cfg.get("use_torch_compile", False)),
            "torch_num_threads": int(zmclip_cfg.get("torch_num_threads", 0)),
            "torch_num_interop_threads": int(zmclip_cfg.get("torch_num_interop_threads", 0)),
            "warmup_iterations": int(zmclip_cfg.get("warmup_iterations", 1)),
        }
    raise ValueError(f"Unsupported worker backend: {backend}. Supported backends: tensorflow, torch")


def _build_worker_server_command(
    *,
    python_executable: str,
    backend_cfg: Dict[str, Any],
    runtime_cfg: Dict[str, Any],
    model_path: Path,
    schema_path: Path,
    host: str,
    port: int,
    model_name: str,
) -> List[str]:
    cmd = [
        str(python_executable),
        "-m",
        "hotvect.worker.litserve_server",
        "--model-path",
        str(model_path),
        "--schema-path",
        str(schema_path),
        "--model-name",
        str(model_name),
        "--host",
        host,
        "--port",
        str(port),
        "--accelerator",
        str(runtime_cfg.get("accelerator", "auto")),
        "--devices",
        _resolve_worker_server_litserve_devices_arg(runtime_cfg, os.environ.get("CUDA_VISIBLE_DEVICES")),
        "--workers-per-device",
        str(int(runtime_cfg.get("workers_per_device", 1))),
        "--request-timeout-seconds",
        str(float(runtime_cfg.get("request_timeout_ms", 30_000)) / 1000.0),
    ]
    cmd.extend(["--backend", str(backend_cfg["backend"])])
    if backend_cfg.get("debug_include_tf_inputs"):
        cmd.append("--debug-include-tf-inputs")
    if backend_cfg["backend"] == "torch":
        cmd.extend(["--torch-model-name", str(backend_cfg["torch_model_name"])])
        if backend_cfg.get("use_torch_compile"):
            cmd.append("--use-torch-compile")
        if int(backend_cfg.get("torch_num_threads", 0)) > 0:
            cmd.extend(["--torch-num-threads", str(int(backend_cfg["torch_num_threads"]))])
        if int(backend_cfg.get("torch_num_interop_threads", 0)) > 0:
            cmd.extend(
                [
                    "--torch-num-interop-threads",
                    str(int(backend_cfg["torch_num_interop_threads"])),
                ]
            )
        cmd.extend(["--warmup-iterations", str(int(backend_cfg.get("warmup_iterations", 1)))])
    return cmd


def _resolve_worker_serve_scope_config(algorithm_definition: Dict[str, Any], scope: str) -> tuple[str, str, Dict[str, Any]]:
    algo_params = algorithm_definition.get("algorithm_parameters")
    if not isinstance(algo_params, dict):
        raise ValueError("Algorithm definition is missing algorithm_parameters")

    scoped_configs: Dict[str, tuple[str, Dict[str, Any]]] = {}
    for scope_name in ("realtime", "batch"):
        scope_node = algo_params.get(scope_name)
        if scope_node is None:
            continue
        if not isinstance(scope_node, dict):
            raise ValueError(f"algorithm_parameters.{scope_name} must be an object when present")
        litserve_cfg = scope_node.get("litserve")
        direct_workers_cfg = scope_node.get("direct_workers")
        if isinstance(litserve_cfg, dict):
            scoped_configs[scope_name] = ("litserve", copy.deepcopy(litserve_cfg))
            continue
        if litserve_cfg is not None:
            raise ValueError(f"algorithm_parameters.{scope_name}.litserve must be an object")
        if isinstance(direct_workers_cfg, dict):
            scoped_configs[scope_name] = ("direct_workers", copy.deepcopy(direct_workers_cfg))
            continue
        if direct_workers_cfg is not None:
            raise ValueError(f"algorithm_parameters.{scope_name}.direct_workers must be an object")

    def _scope_entry(scope_name: str) -> tuple[str, str, Dict[str, Any]]:
        cfg = scoped_configs.get(scope_name)
        if cfg is None:
            raise ValueError(f"algorithm_parameters.{scope_name}.litserve or .direct_workers is not configured")
        return scope_name, cfg[0], cfg[1]

    if scope != "auto":
        if scope in {"realtime", "batch"}:
            return _scope_entry(scope)
        raise ValueError(f"No worker serve config found for scope '{scope}'")

    for scope_name in ("realtime", "batch"):
        cfg = scoped_configs.get(scope_name)
        if cfg is not None:
            return scope_name, cfg[0], cfg[1]

    raise ValueError(
        "Algorithm definition does not contain a usable worker serve config. "
        "Expected algorithm_parameters.{realtime,batch}.litserve or .direct_workers"
    )


class ServeCommand(BaseCommand):
    def supports_passthrough_args(self) -> bool:
        return True

    def get_name(self) -> str:
        return "serve"

    def get_help(self) -> str:
        return "Serve the full algorithm over HTTP for local debugging"

    def get_description(self) -> str:
        return "Start the full Java algorithm runtime over HTTP. Add --ui to enable the browser UI on the same server."

    def add_arguments(self, parser: argparse.ArgumentParser) -> None:
        parser.add_argument("--algorithm-jar", required=True, help="Path to algorithm JAR file (required)")
        parser.add_argument(
            "--algorithm-name",
            required=True,
            type=_parse_algorithm_name,
            help="Algorithm name (matches algorithm definition) (required)",
        )
        parser.add_argument(
            "--algorithm-override",
            help="Path to JSON file containing algorithm configuration overrides (optional)",
        )
        parser.add_argument("--parameter-path", required=True, help="Path to parameters ZIP from training (required)")
        parser.add_argument("--port", type=int, required=True, help="Port to bind to (required; must be non-zero)")
        parser.add_argument("--host", help="Host to bind to (default: 127.0.0.1)")
        parser.add_argument("--ui", action="store_true", help="Enable browser UI routes and static assets")
        parser.add_argument(
            "--source-path",
            help="Directory containing offline examples. Required with --ui.",
        )
        parser.add_argument(
            "--action-metadata-path",
            help="Directory containing action metadata keyed by action_id (UI only)",
        )
        parser.add_argument(
            "--demo-sqlite-path",
            help="SQLite cache path used by the UI mode",
        )
        parser.add_argument(
            "--max-request-mib",
            type=int,
            default=256,
            help="Maximum request size accepted by the server in MiB (default: 256)",
        )

    def execute(self, args: argparse.Namespace) -> None:
        if args.port in (None, 0):
            raise ValueError("--port is required and must be non-zero")
        if not (1 <= int(args.port) <= 65535):
            raise ValueError(f"--port must be between 1 and 65535, got {args.port}")
        if args.ui and not args.source_path:
            raise ValueError("--source-path is required with --ui")
        if not args.ui:
            if args.source_path:
                raise ValueError("--source-path is only supported with --ui")
            if args.action_metadata_path:
                raise ValueError("--action-metadata-path is only supported with --ui")
            if args.demo_sqlite_path:
                raise ValueError("--demo-sqlite-path is only supported with --ui")

        host = _resolve_host(args.host)
        jvm_args = getattr(args, "_jvm_args", [])
        cmd = ["java"]
        cmd.extend(jvm_args)
        if not any(arg.startswith("-Xmx") or arg.startswith("-XX:MaxRAMPercentage") for arg in jvm_args):
            cmd.append("-XX:MaxRAMPercentage=90")
        if "-XX:+ExitOnOutOfMemoryError" not in jvm_args:
            cmd.append("-XX:+ExitOnOutOfMemoryError")
        if "-cp" not in jvm_args:
            cmd.extend(["-cp", str(hotvect.hotvectjar.HOTVECT_ALGORITHM_DEMO_JAR_PATH)])
        cmd.extend(
            [
                "com.hotvect.algorithmdemo.Main",
                "--algorithm-jar",
                str(args.algorithm_jar),
                "--algorithm-name",
                args.algorithm_name,
                "--parameter-path",
                str(args.parameter_path),
                "--host",
                host,
                "--port",
                str(args.port),
                "--max-request-mib",
                str(args.max_request_mib),
            ]
        )
        if args.algorithm_override:
            cmd.extend(["--algorithm-override", str(args.algorithm_override)])
        if args.ui:
            cmd.append("--ui")
            cmd.extend(["--source-path", str(args.source_path)])
            if args.action_metadata_path:
                cmd.extend(["--action-metadata-path", str(args.action_metadata_path)])
            if args.demo_sqlite_path:
                cmd.extend(["--demo-sqlite-path", str(args.demo_sqlite_path)])

        _run_http_server_process(
            cmd,
            host=host,
            port=int(args.port),
            health_timeout_seconds=120,
            health_request_timeout_seconds=2.0,
        )


class WorkerServeCommand(BaseCommand):
    def get_name(self) -> str:
        return "serve"

    def get_help(self) -> str:
        return "Serve the worker runtime only over HTTP"

    def get_description(self) -> str:
        return "Start a local LitServe worker HTTP endpoint using the backend declared in the algorithm definition. This bypasses JVM feature extraction and expects worker-ready feature rows."

    def add_arguments(self, parser: argparse.ArgumentParser) -> None:
        parser.add_argument("--algorithm-jar", required=True, help="Path to algorithm JAR file (required)")
        parser.add_argument(
            "--algorithm-name",
            required=True,
            type=_parse_algorithm_name,
            help="Model algorithm name (matches algorithm definition) (required)",
        )
        parser.add_argument(
            "--algorithm-override",
            help="Path to JSON file containing algorithm configuration overrides (optional)",
        )
        parser.add_argument("--parameter-path", required=True, help="Path to parameters ZIP from training (required)")
        parser.add_argument("--port", type=int, default=8000, help="Port to bind to (default: 8000; must be non-zero)")
        parser.add_argument("--host", help="Host to bind to (default: 127.0.0.1)")
        parser.add_argument(
            "--scope",
            choices=["auto", "realtime", "batch"],
            default="auto",
            help="Which scope to use. auto prefers realtime, then batch. hv worker serve prefers litserve, then falls back to direct_workers.",
        )
        parser.add_argument(
            "--debug-include-tf-inputs",
            action="store_true",
            help="Include normalized TensorFlow inputs in the LitServe response debug field (local TensorFlow only)",
        )
        parser.add_argument("--keep-temp-dir", action="store_true", help="Keep extracted model/schema temp directory")

    def execute(self, args: argparse.Namespace) -> None:
        import shutil

        algorithm_definition = _load_effective_algorithm_definition(
            args.algorithm_jar,
            args.algorithm_name,
            args.algorithm_override,
        )
        backend = _resolve_worker_backend(algorithm_definition)
        selected_scope, selected_source, runtime_cfg = _resolve_worker_serve_scope_config(algorithm_definition, args.scope)
        logger.info("Using worker serve scope: %s (%s)", selected_scope, selected_source)
        model_name = str(runtime_cfg.get("model_name", args.algorithm_name))

        if args.port in (None, 0):
            raise ValueError("--port is required for local LitServe and must be non-zero")
        if not (1 <= int(args.port) <= 65535):
            raise ValueError(f"--port must be between 1 and 65535, got {args.port}")

        temp_dir = Path(os.path.abspath(os.path.join("/tmp", f"hv-worker-serve-{os.getpid()}-{os.urandom(4).hex()}")))
        temp_dir.mkdir(parents=True, exist_ok=False)
        keep_temp_dir = bool(args.keep_temp_dir or runtime_cfg.get("keep_temp_dir", False))

        clean_exit = False
        try:
            model_path, schema_path = _extract_model_and_schema_from_parameters(
                args.parameter_path,
                args.algorithm_name,
                str(temp_dir),
            )
            env = os.environ.copy()
            env["PYTHONUNBUFFERED"] = "1"
            python_root = Path(__file__).resolve().parent.parent
            existing_pythonpath = env.get("PYTHONPATH", "")
            env["PYTHONPATH"] = f"{python_root}:{existing_pythonpath}" if existing_pythonpath else str(python_root)

            env_overrides = _stringify_env_overrides(
                runtime_cfg.get("env"),
                field_name=f"algorithm_parameters.{selected_scope}.{selected_source}.env",
            )
            env.update(env_overrides)
            env["CUDA_VISIBLE_DEVICES"] = _resolve_worker_server_cuda_visible_devices(
                runtime_cfg,
                os.environ.get("CUDA_VISIBLE_DEVICES"),
            )

            python_executable = (
                os.environ.get("HOTVECT_PYTHON_EXECUTABLE")
                or runtime_cfg.get("python_executable")
                or sys.executable
            )
            host = _resolve_host(args.host)
            debug_include_tf_inputs = bool(args.debug_include_tf_inputs)
            debug_cfg = runtime_cfg.get("debug")
            if isinstance(debug_cfg, dict):
                debug_include_tf_inputs = debug_include_tf_inputs or bool(debug_cfg.get("include_tf_inputs", False))
            backend_cfg = _resolve_worker_backend_cfg(
                backend,
                algorithm_definition,
                debug_include_tf_inputs=debug_include_tf_inputs,
            )
            cmd = _build_worker_server_command(
                python_executable=str(python_executable),
                backend_cfg=backend_cfg,
                runtime_cfg=runtime_cfg,
                model_path=model_path,
                schema_path=schema_path,
                host=host,
                port=int(args.port),
                model_name=model_name,
            )

            startup_timeout_ms = runtime_cfg.get("startup_timeout_ms", 30_000)
            if not isinstance(startup_timeout_ms, int) or startup_timeout_ms <= 0:
                raise ValueError(f"startup_timeout_ms must be a positive integer, got: {startup_timeout_ms}")
            _run_http_server_process(
                cmd,
                host=host,
                port=int(args.port),
                health_timeout_seconds=max(1, int(startup_timeout_ms / 1000)),
                health_request_timeout_seconds=max(0.5, float(runtime_cfg.get("request_timeout_ms", 30_000)) / 1000.0),
                env=env,
            )
            clean_exit = True
        except KeyboardInterrupt:
            clean_exit = True
            raise
        finally:
            if keep_temp_dir:
                logger.info("Temp directory retained at: %s", temp_dir)
            elif clean_exit:
                shutil.rmtree(temp_dir, ignore_errors=True)
            else:
                logger.warning("Temp directory retained for debugging at: %s", temp_dir)


class WorkerCommand(BaseCommand):
    def __init__(self) -> None:
        self.serve_command = WorkerServeCommand()

    def get_name(self) -> str:
        return "worker"

    def get_help(self) -> str:
        return "Worker-runtime HTTP debugging utilities"

    def get_description(self) -> str:
        return "Utilities for worker-only debugging. These commands bypass JVM feature extraction and operate on the Python worker runtime directly."

    def add_arguments(self, parser: argparse.ArgumentParser) -> None:
        subparsers = parser.add_subparsers(dest="worker_command", required=True)
        serve_parser = subparsers.add_parser(
            "serve",
            help=self.serve_command.get_help(),
            description=self.serve_command.get_description(),
        )
        self.serve_command.add_arguments(serve_parser)

    def execute(self, args: argparse.Namespace) -> None:
        if args.worker_command == "serve":
            self.serve_command.execute(args)
            return
        raise ValueError(f"Unknown worker command: {args.worker_command}")


class BacktestCommand(BaseCommand):
    def get_name(self) -> str:
        return "backtest"

    def get_help(self) -> str:
        return "Run backtest on git references to compare algorithm performance"

    def get_description(self) -> str:
        return "Run backtest on git references to compare algorithm performance across different versions or configurations. For SageMaker execution, returns immediately after job submission without waiting for completion."

    def add_arguments(self, parser: argparse.ArgumentParser) -> None:
        # Create mutually exclusive group for git references
        ref_group = parser.add_mutually_exclusive_group(required=True)
        ref_group.add_argument("--git-reference", action='append', dest='git_references',
                              help="Git reference (branch/commit) to test. Can be specified multiple times for multiple references")
        ref_group.add_argument("--backtest-config",
                              help="Path to JSON file containing list of git references and their overrides")

        parser.add_argument("--algorithm-override", action='append', dest='algorithm_overrides',
                          help="Path to JSON file containing algorithm configuration overrides. If one override provided, applies to all git references. If multiple overrides provided, applies to git references in order (optional)")

        # Required arguments
        parser.add_argument("--algo-repo-url", required=True,
                          help="Git repository URL for the algorithm (required)")
        parser.add_argument("--data-base-dir", default="",
                          help="Base directory containing training and test data (default: from ~/.hotvect/config.json)")
        parser.add_argument("--output-base-dir", default="",
                          help="Base directory where backtest results will be saved (default: from ~/.hotvect/config.json)")
        parser.add_argument("--scratch-dir", default="",
                          help="Directory for temporary files like JARs and working data during backtest execution (default: from ~/.hotvect/config.json)")
        parser.add_argument("--last-test-time", required=True,
                          help="Last test time in YYYY-MM-DD format, e.g., '2025-08-05' (required)")

        # Optional arguments
        parser.add_argument("--number-of-runs", type=int, default=1,
                          help="Number of backtest runs to execute (default: 1)")
        parser.add_argument("--extra-jvm-args",
                          help="Additional JVM arguments, comma-separated, e.g., '-Xmx176g,-XX:+UseG1GC' (optional)")
        parser.add_argument("--sagemaker", action="store_true", help="Execute this backtest remotely on SageMaker")
        parser.add_argument(
            "--sagemaker-job-prefix",
            help="Required when using --sagemaker or --sagemaker-config. Must be a valid SageMaker TrainingJobName prefix.",
        )
        parser.add_argument("--sagemaker-config", help="Path to JSON file containing SageMaker training job configuration (optional)")
        parser.add_argument("--role-arn", help="SageMaker job execution role ARN (CreateTrainingJob.RoleArn) (optional)")
        parser.add_argument(
            "--assume-role-arn",
            help="AWS role ARN to assume for SageMaker submission (optional; defaults to using current AWS credentials)",
        )
        parser.add_argument("--s3-output-base", help="S3 output base prefix used in template-free SageMaker mode (OutputDataConfig.S3OutputPath)")
        parser.add_argument("--instance-type", help="SageMaker instance type used in template-free SageMaker mode (ResourceConfig.InstanceType)")
        parser.add_argument("--volume-gb", type=int, help="EBS volume size in GB (ResourceConfig.VolumeSizeInGB)")
        parser.add_argument("--max-runtime-seconds", type=int, help="Max runtime in seconds (StoppingCondition.MaxRuntimeInSeconds)")
        parser.add_argument("--training-image", dest="training_image", help="Training image URI override (AlgorithmSpecification.TrainingImage)")
        parser.add_argument("--n-process", type=int, default=1,
                          help="Number of parallel processes for local execution (default: 1)")
        parser.add_argument("--max-threads-per-process", type=int, default=-1,
                          help="Maximum threads per process for local execution (default: auto-calculated)")
        parser.add_argument("--clean", action='store_true',
                          help="Clean output directories before starting backtest (optional)")
        parser.add_argument("--no-performance-test", action='store_true',
                          help="Disable system performance testing (optional)")
        parser.add_argument(
            "--cache",
            dest="cache_base_dir",
            default=None,
            help="Enable Hotvect pipeline caching (local path or s3://example-bucket).",
        )
        parser.add_argument(
            "--cache-scope",
            choices=["major", "minor", "patch", "hyperparam"],
            default="hyperparam",
            help=(
                "Cache key scope across algorithm versions. "
                "major=X.*, minor=X.Y.*, patch=X.Y.Z, hyperparam=X.Y.Z[-hyperparameter_version] (default: hyperparam)."
            ),
        )
        parser.add_argument(
            "--cache-refresh",
            action="store_true",
            help="Ignore cache reads (force recompute) while still writing results to cache.",
        )
        parser.add_argument(
            "--performance-test-samples",
            type=int,
            help="Pin perf-test sample size for comparability (pipeline performance-test --samples)",
        )
        parser.add_argument("--auto-attach-data-default-s3-base",
                          help="Default S3 base URI used when dependencies do not specify explicit s3_uri (e.g., s3://bucket/tables/). Auto-attach is always enabled in SageMaker mode.")
        parser.add_argument("--auto-attach-data-environment", default='production',
                          help="Environment key to use when dependency s3_uri is a map (e.g., production, prod, test, staging). Default: production")

    def execute(self, args: argparse.Namespace) -> None:
        from datetime import date
        from hotvect.backtest import run_backtest_on_git_references
        from hotvect.extra.config import load_config
        from hotvect.mlutils import standard_evaluation
        import json

        cfg = load_config()
        cfg_dirs = cfg.get("directories", {}) if isinstance(cfg, dict) else {}
        if not args.data_base_dir:
            args.data_base_dir = cfg_dirs.get("data_base_dir", "")
        if not args.output_base_dir:
            args.output_base_dir = cfg_dirs.get("output_base_dir", "")
        if not args.scratch_dir:
            args.scratch_dir = cfg_dirs.get("scratch_dir", "")

        # Parse git references and overrides
        if args.backtest_config:
            # Load from config file
            with open(args.backtest_config, 'r') as f:
                config = json.load(f)
            git_references = [(item['git_reference'], item.get('algorithm_definition_override')) for item in config]
        else:
            # Build from command line arguments
            git_references = []
            overrides = args.algorithm_overrides or []

            # Smart padding logic and validation
            if len(overrides) == 1 and len(args.git_references) > 1:
                logger.info(f"Single algorithm override provided for {len(args.git_references)} git references. Applying the same override to all references: {overrides[0]}")
                # Pad with the single override instead of None
                while len(overrides) < len(args.git_references):
                    overrides.append(overrides[0])
            elif len(overrides) > 1 and len(overrides) != len(args.git_references):
                # Multiple overrides provided but count doesn't match git references - fail
                import sys
                print(f"Error: {len(overrides)} algorithm overrides provided but {len(args.git_references)} git references specified. Numbers don't match.", file=sys.stderr)
                sys.exit(2)
            else:
                # Either no overrides, or exact match, or single git ref - use original padding logic
                while len(overrides) < len(args.git_references):
                    overrides.append(None)

            for i, git_ref in enumerate(args.git_references):
                override = None
                if i < len(overrides) and overrides[i]:
                    with open(overrides[i], 'r') as f:
                        override = json.load(f)
                    logger.info(f"Applied algorithm override from {overrides[i]} to git reference {git_ref}")
                else:
                    logger.info(f"No algorithm override applied to git reference {git_ref}")
                git_references.append((git_ref, override))

        # Parse JVM options
        jvm_options = None
        if args.extra_jvm_args:
            jvm_options = [arg.strip() for arg in args.extra_jvm_args.split(',')]

        remote_mode = bool(args.sagemaker or args.sagemaker_config)

        # Apply perf-test sample pinning into algo overrides (pipeline perf-test --samples)
        if args.performance_test_samples is not None:
            git_references = [
                (ref, apply_performance_test_samples_override(override, args.performance_test_samples))
                for (ref, override) in git_references
            ]

        # Resolve SageMaker training job definition (template optional)
        sagemaker_training_job_definition = None
        if remote_mode:
            if not args.sagemaker_job_prefix:
                raise ValueError("--sagemaker-job-prefix is required for SageMaker execution")
            validate_job_prefix(args.sagemaker_job_prefix)

            template_source = resolve_template_path(args.sagemaker_config)
            template_job_def = None
            if template_source.path:
                template_job_def = json.loads(Path(template_source.path).read_text())

            template_free = template_job_def is None
            if template_free:
                _require_for_template_free(args.role_arn, "--role-arn")
                _require_for_template_free(args.s3_output_base, "--s3-output-base")
                _require_for_template_free(args.instance_type, "--instance-type")

            # Backtest sets TrainingImage per git ref inside the pipeline execution. Allow missing here.
            base_training_image = resolve_training_image(
                cli_training_image=args.training_image,
                algorithm_definition=None,
                template_job_def=template_job_def,
            )

            sagemaker_training_job_definition = build_training_job_definition(
                template_job_def=template_job_def,
                training_job_name=args.sagemaker_job_prefix,
                role_arn=args.role_arn,
                s3_output_base=args.s3_output_base,
                instance_type=args.instance_type,
                volume_gb=args.volume_gb,
                max_runtime_seconds=args.max_runtime_seconds,
                training_image=base_training_image,
                require_training_image=False if base_training_image is None else True,
            )

        # Validate base dirs
        if not args.output_base_dir:
            import sys
            print(
                "Error: --output-base-dir is required (or set directories.output_base_dir in ~/.hotvect/config.json)",
                file=sys.stderr,
            )
            sys.exit(2)
        if not args.scratch_dir:
            import sys
            print(
                "Error: --scratch-dir is required (or set directories.scratch_dir in ~/.hotvect/config.json)",
                file=sys.stderr,
            )
            sys.exit(2)

        # Validate data-base-dir requirement for local execution
        if not sagemaker_training_job_definition and not args.data_base_dir:
            import sys
            print(
                "Error: --data-base-dir is required for local execution (or set directories.data_base_dir in ~/.hotvect/config.json)",
                file=sys.stderr,
            )
            sys.exit(2)

        # For SageMaker mode, use placeholder if data_base_dir not provided
        if remote_mode and not args.data_base_dir:
            args.data_base_dir = args.scratch_dir  # placeholder; remote uses channels

        # Parse last test time
        last_test_time = date.fromisoformat(args.last_test_time)

        if args.cache_refresh and not args.cache_base_dir:
            import sys

            print("Error: --cache-refresh requires --cache.", file=sys.stderr)
            sys.exit(2)

        logger.info(f"Starting backtest with {len(git_references)} git references")
        logger.info(f"Git references: {[ref[0] for ref in git_references]}")
        logger.info(f"SageMaker mode: {'enabled' if remote_mode else 'disabled'}")

        # Use the existing run_backtest_on_git_references function which has proper job naming
        results = run_backtest_on_git_references(
            algo_repo_url=args.algo_repo_url,
            algo_git_references=git_references,
            data_base_dir=args.data_base_dir,
            output_base_dir=args.output_base_dir,
            hyperparameter_base_dir=args.scratch_dir,
            evaluation_function=standard_evaluation,
            last_test_time=last_test_time,
            number_of_runs=args.number_of_runs,
            jvm_options=jvm_options,
            sagemaker_training_job_definition=sagemaker_training_job_definition,
            role_arn_to_assume=args.assume_role_arn,
            training_image_override=args.training_image,
            clean=args.clean,
            system_performance_test=not args.no_performance_test,
            auto_attach_data_default_s3_base=args.auto_attach_data_default_s3_base,
            auto_attach_data_environment=args.auto_attach_data_environment,
            cache_base_dir=args.cache_base_dir,
            cache_scope=args.cache_scope,
            cache_refresh=args.cache_refresh,
        )

        # Display results
        if sagemaker_training_job_definition:
            logger.info("SageMaker jobs submitted successfully!")
            for result in results:
                logger.info(f"Git reference: {result.algo_git_reference}")
                if result.error:
                    logger.error(f"Error: {result.error}")
                elif result.backtest_iteration_results:
                    for iteration in result.backtest_iteration_results:
                        if iteration.result and 'training_job_name' in iteration.result:
                            logger.info(f"  SageMaker job submitted: {iteration.result['training_job_name']}")
        else:
            logger.info("Local backtest completed!")
            for result in results:
                logger.info(f"Git reference: {result.algo_git_reference}")
                if result.error:
                    logger.error(f"Error: {result.error}")
                elif result.backtest_iteration_results:
                    for iteration in result.backtest_iteration_results:
                        if iteration.result:
                            logger.info(f"Results for {iteration.parameter_version}: {iteration.result}")

        logger.info("Backtest execution completed")



def main():
    # Define available commands
    commands = {
        'audit': AuditCommand(),
        'performance-test': PerformanceTestCommand(),
        'encode': EncodeCommand(),
        'predict': PredictCommand(),
        'generate-state': GenerateStateCommand(),
        'list-transformations': ListTransformationsCommand(),
        'evaluate': EvaluateCommand(),
        'train': TrainCommand(),
        'backtest': BacktestCommand(),
        'serve': ServeCommand(),
        'worker': WorkerCommand(),
    }

    global_parser = argparse.ArgumentParser(add_help=False)
    global_parser.add_argument(
        '--version',
        action=_HotvectVersionAction,
        nargs=0,
        help="Show version and exit",
    )

    parser = argparse.ArgumentParser(
        prog='hv',
        description="Hotvect Command Line Interface (CLI) tool for performing various operations like encoding, predicting, auditing, etc.",
        epilog="Use 'hv <command> -h' to see help for each command.",
        add_help=True,
        parents=[global_parser],
    )

    subparsers = parser.add_subparsers(dest='command', help='Available subcommands')

    # Add subparsers for each command
    for command_name, command_instance in commands.items():
        subparser = subparsers.add_parser(
            command_name,
            help=command_instance.get_help(),
            description=command_instance.get_description(),
            parents=[global_parser],
        )
        command_instance.add_arguments(subparser)

    # If no arguments are provided, show the help message
    if len(sys.argv) == 1:
        parser.print_help(sys.stderr)
        sys.exit(1)

    raw_argv = sys.argv[1:]
    passthrough_args: list[str] = []
    if "--" in raw_argv:
        separator_index = raw_argv.index("--")
        passthrough_args = raw_argv[separator_index + 1:]
        raw_argv = raw_argv[:separator_index]

    args = parser.parse_args(raw_argv)

    if passthrough_args:
        if not getattr(args, "command", None):
            parser.error("Arguments after '--' require a passthrough-enabled command before the separator.")
        command_instance = commands.get(args.command)
        if command_instance is None or not command_instance.supports_passthrough_args():
            parser.error(
                f"Command '{args.command}' does not accept passthrough arguments after '--'. "
                "Use explicit command flags instead."
            )

    # Store JVM args for passthrough-enabled Java commands / serve.
    args._jvm_args = passthrough_args

    # Execute the selected command
    if args.command in commands:
        commands[args.command].execute(args)
    else:
        parser.error(f"Unknown command {args.command}")


if __name__ == '__main__':
    main()
