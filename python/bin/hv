#!/usr/bin/env python3
import argparse
import json
import logging
import sys
from abc import ABC, abstractmethod
from pathlib import Path
from typing import List

import hotvect.hotvectjar
from hotvect.utils import execute_command_with_live_output
import hotvect.mlutils as mlutils
from hotvect.pyhotvect import AlgorithmPipeline, AlgorithmPipelineContext

logging.basicConfig(
    level=logging.INFO,
    stream=sys.stdout,
    format='%(asctime)s:%(levelname)s:%(name)s:%(funcName)s:%(message)s'
)
logger = logging.getLogger(__name__)


class BaseCommand(ABC):
    """Base class for all hv commands."""

    @abstractmethod
    def get_name(self) -> str:
        """Return the command name."""
        pass

    @abstractmethod
    def get_help(self) -> str:
        """Return the short help message."""
        pass

    @abstractmethod
    def get_description(self) -> str:
        """Return the detailed description."""
        pass

    @abstractmethod
    def add_arguments(self, parser: argparse.ArgumentParser) -> None:
        """Add command-specific arguments to the parser."""
        pass

    @abstractmethod
    def execute(self, args: argparse.Namespace) -> None:
        """Execute the command with parsed arguments."""
        pass


class JavaCommand(BaseCommand):
    """Base class for commands that execute Java with hotvect JAR."""

    def add_arguments(self, parser: argparse.ArgumentParser) -> None:
        """Add common Java command arguments."""
        parser.add_argument("--algorithm-jar", required=True,
                          help="Path to the JAR file containing the algorithm implementation (required)")
        parser.add_argument("--algorithm-name", required=True,
                          help="Name of the algorithm to execute (required)")
        parser.add_argument("--metadata-path",
                          help="Path where the operation's metadata will be saved (optional, auto-generated if not specified)")

        # Add source-path with default settings, subclasses can override
        source_required, source_help = self.get_source_path_config()
        parser.add_argument("--source-path", required=source_required, help=source_help)

        parser.add_argument("--dest-path",
                          help="Path where the operation results will be saved (optional, auto-generated if not specified)")
        parser.add_argument("--parameter-path",
                          help="Path to the trained model parameter file (required for predict/audit, optional for others)")
        parser.add_argument("--dest-schema-path",
                          help="Path where the feature schema description will be saved (optional, used in encoding operations)")
        parser.add_argument("--samples", type=int,
                          help="Number of samples to process, useful for testing with smaller datasets (optional)")

        # Add command-specific arguments
        self.add_command_arguments(parser)

    def get_source_path_config(self):
        """Return (required, help_text) for --source-path argument. Override in subclasses."""
        return False, "Path to the input data source for the operation (optional for some commands)"

    def add_command_arguments(self, parser: argparse.ArgumentParser) -> None:
        """Override to add command-specific arguments."""
        pass

    def execute(self, args: argparse.Namespace) -> None:
        """Execute Java command with common logic."""
        # Set default paths if not provided
        command_name = self.get_name()

        if not getattr(args, 'metadata_path', None):
            metadata_path = f"{args.algorithm_name}.{command_name}.metadata.json"
            logger.info(f"Metadata path not provided. Using default: {metadata_path}")
            args.metadata_path = metadata_path

        if not getattr(args, 'dest_path', None):
            dest_path = f"{args.algorithm_name}.{command_name}.output"
            logger.info(f"Destination path not provided. Using default: {dest_path}")
            args.dest_path = dest_path

        if not getattr(args, 'dest_schema_path', None):
            dest_schema_path = f"{args.algorithm_name}.{command_name}.output.schema"
            logger.info(f"Destination schema path not provided. Using default: {dest_schema_path}")
            args.dest_schema_path = dest_schema_path

        # Get JVM args that were passed after the command
        jvm_args = getattr(args, '_jvm_args', [])

        self.run_java_command(args, jvm_args)

    def run_java_command(self, args: argparse.Namespace, jvm_args: List[str]) -> None:
        """Run the Java command."""
        cmd = ["java"]
        cmd.extend(jvm_args)
        if not any(arg.startswith("-Xmx") for arg in jvm_args):
            cmd.append("-Xmx32g")
        if "-XX:+ExitOnOutOfMemoryError" not in jvm_args:
            cmd.append("-XX:+ExitOnOutOfMemoryError")
        if "-cp" not in jvm_args:
            cmd.extend(["-cp", str(hotvect.hotvectjar.HOTVECT_JAR_PATH)])

        cmd.extend([
            "com.hotvect.offlineutils.commandline.Main",
            "--algorithm-jar", str(args.algorithm_jar),
            "--algorithm-definition", args.algorithm_name,
            "--meta-data", str(args.metadata_path),
            f"--{self.get_name()}",
            "--dest", str(args.dest_path)
        ])

        if args.source_path:
            cmd.extend(["--source", str(args.source_path)])

        # Always use ordered processing
        cmd.append("--ordered")

        if self.get_name() == "encode":
            cmd.extend(["--dest-schema-description", str(args.dest_schema_path)])

        if getattr(args, 'parameter_path', None):
            cmd.extend(["--parameters", str(args.parameter_path)])

        if getattr(args, 'samples', None):
            cmd.extend(["--samples", str(args.samples)])

        cmd_str = ' '.join(map(str, cmd))
        logger.info(f"Running command: {cmd_str}")
        execute_command_with_live_output(cmd_str, sys.stdout.write)


class AuditCommand(JavaCommand):
    def get_name(self) -> str:
        return "audit"

    def get_help(self) -> str:
        return "Generate human-readable audit data showing feature transformations and calculations"

    def get_description(self) -> str:
        return "Perform feature transformation on input data and save results as human-readable JSONL format. This is useful for debugging algorithms, inspecting calculated features, and understanding how input data is transformed by the feature engineering pipeline."

    def get_source_path_config(self):
        return True, "Path to the input data source for auditing (required)"


