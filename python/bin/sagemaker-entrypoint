#!/usr/bin/env python3

"""Training in SageMaker.

This module has code that will facilitate the execution of the Hotvect algorithms in SageMaker.

This module can be executed as a script. This is convenient as it can set as the EntryPoint for
the Dockerfile that will create the image that will run in SageMaker.
"""
import logging
import os
from os import path
from typing import Dict
from sagemaker_training.environment import Environment


import s3fs
from hotvect.pyhotvect import AlgorithmPipeline
from hotvect.sagemaker import (
    WRITE_METADATA_ENV_VARIABLE,
    WRITE_OUTPUT_ENV_VARIABLE,
    SagemakerAlgorithmPipelineRebuilder,
)

from hotvect.sagemaker_exp import SageMakerScriptExecutor


logger = logging.getLogger(__name__)

SHOULD_UPDATE_EMS_PARAMETER_VAR = "should_update_ems_parameter"
EMS_S3_OUTPUT_PREFIX_VAR = "ems_s3_output_prefix"
EMS_ENV_VAR = "ems_env"
ZALANDO_TOKEN_SECRET_ID_VAR = "zalando_token_secret_id"
REQUIRED_PARAMS_FOR_EMS_UPDATE = [
    EMS_S3_OUTPUT_PREFIX_VAR,
    EMS_ENV_VAR,
    ZALANDO_TOKEN_SECRET_ID_VAR,
]


def load_emsclient():
    try:
        from emsclient.auth import SecretsManagerAuth
        from emsclient.ems import Ems, EmsConnection
        from emsclient.ems import Environment as EmsEnv
        from emsclient.models import AlgorithmName, AlgorithmParameterSpec
    except ImportError as exc:
        raise RuntimeError(
            "EMS parameter updates require the internal-only 'emsclient' package. "
            "Disable should_update_ems_parameter when using OSS Hotvect."
        ) from exc

    return SecretsManagerAuth, Ems, EmsConnection, EmsEnv, AlgorithmName, AlgorithmParameterSpec


def train():
    hotvect_rebuilder = SagemakerAlgorithmPipelineRebuilder()
    hyperparameters: Dict = hotvect_rebuilder.sagemaker_env.hyperparameters

    should_update_ems_parameter = hyperparameters.get(SHOULD_UPDATE_EMS_PARAMETER_VAR, False)
    if should_update_ems_parameter:
        logger.info(
            "Training for EMS update. output.tar.gz and model.tar.gz won't be uploaded to s3"
        )
        disable_writing_sagemaker_tar_files()
        check_for_ems_update_required_params(hyperparameters)
    else:
        logger.info("The results of this training won't be uploaded to EMS.")

    hotvect_rebuilder.rebuild_pipeline_and_run()
    logger.info("Hotvect pipeline finished.")

    if should_update_ems_parameter:
        ems_env = hyperparameters.get(EMS_ENV_VAR)
        ems_s3_output_prefix = hyperparameters.get(EMS_S3_OUTPUT_PREFIX_VAR)
        secret_id = hyperparameters.get(ZALANDO_TOKEN_SECRET_ID_VAR)
        training_result_updater = EmsUpdaterAgent(
            algorithm_pipeline=hotvect_rebuilder.algorithm_pipeline,
            output_s3_path=ems_s3_output_prefix,
            ems_env=ems_env,
            secret_id=secret_id,
        )
        training_result_updater.upload_result_and_update_ems()


def script():
    script_rebuilder = SageMakerScriptExecutor()
    result = script_rebuilder.run()
    logger.info(f"Hotvect script execution finished {result}")


def main():
    setup_logging(logging.INFO)
    sagemaker_env = Environment()
    if "s3_uri_custom_jar" in sagemaker_env.hyperparameters.keys():
        script()
    else:
        train()


def setup_logging(log_level):
    logging.basicConfig(
        level=log_level,
        format="SageMakerExecutor:{%(pathname)s:%(lineno)d} %(levelname)s - %(message)s",
    )


def check_for_ems_update_required_params(hyperparameters):
    missing_parameters = list(
        filter(lambda x: x not in hyperparameters, REQUIRED_PARAMS_FOR_EMS_UPDATE)
    )
    if missing_parameters:
        raise KeyError(
            f"The following mandatory parameters needed to update EMS are missing: {missing_parameters}"
        )


def disable_writing_sagemaker_tar_files():
    os.environ.update({WRITE_METADATA_ENV_VARIABLE: "False", WRITE_OUTPUT_ENV_VARIABLE: "False"})


class EmsUpdaterAgent:
    def __init__(
        self,
        algorithm_pipeline: AlgorithmPipeline,
        output_s3_path: str,
        ems_env: str,
        secret_id: str,
    ):
        self._algorithm_pipeline: AlgorithmPipeline = algorithm_pipeline
        self._output_s3_path: str = output_s3_path
        (
            SecretsManagerAuth,
            Ems,
            EmsConnection,
            EmsEnv,
            AlgorithmName,
            AlgorithmParameterSpec,
        ) = load_emsclient()
        self._algorithm_name_type = AlgorithmName
        self._algorithm_parameter_spec_type = AlgorithmParameterSpec
        self._ems_client = Ems(
            EmsConnection(environment=EmsEnv[ems_env], bearer_auth=SecretsManagerAuth(secret_id))
        )

    def upload_result_and_update_ems(self):
        self._upload_training_parameters_to_s3()
        self._update_parameter_in_ems()

    def _upload_training_parameters_to_s3(self):
        logger.info("Uploading training parameter to S3")
        metadata_remote_path = path.join(self._output_s3_path, "metadata/")
        parameter_zip_s3_uri = path.join(
            self._output_s3_path, f"{self._algorithm_pipeline.parameter_version}.parameters.zip"
        )

        fs = s3fs.S3FileSystem()
        fs.put(
            os.path.join(str(self._algorithm_pipeline.algorithm_pipeline_context.metadata_base_path), '*'),
            metadata_remote_path,
            recursive=True,
        )
        fs.put(self._algorithm_pipeline.predict_parameter_file_path(), parameter_zip_s3_uri)

    def _update_parameter_in_ems(self):
        logger.info("Updating EMS with the training parameters.")
        algorithm = self._algorithm_name_type(
            algorithm_name=self._algorithm_pipeline.algorithm_name,
            algorithm_version=self._algorithm_pipeline.algorithm_version,
        )
        parameter_zip_s3_uri = os.path.join(
            self._output_s3_path, f"{self._algorithm_pipeline.parameter_version}.parameters.zip"
        )
        algorithm_parameter_spec = self._algorithm_parameter_spec_type(
            algorithm_parameter_id=self._algorithm_pipeline.parameter_version,
            algorithm=algorithm,
            evaluation_results="",
            absolute_s3_path=parameter_zip_s3_uri,
        )
        self._ems_client.create_algorithm_parameter(algorithm_parameter_spec)
        logger.info(
            "Algorithm Parameter %s created successfully.",
            self._algorithm_pipeline.parameter_version,
        )


if __name__ == "__main__":
    main()
