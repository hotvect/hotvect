#!/usr/bin/env python3
import argparse
import copy
import glob
import json
import logging
import os
import subprocess
import sys
import traceback
from json import JSONDecodeError
from pathlib import Path
from typing import Any

from catboost import CatBoostClassifier, CatBoostRanker, CatBoostRegressor, Pool

RANDOM_SEED = 4966060

logging.basicConfig(
    level=logging.DEBUG,
    format="Catboost Executable: %(asctime)s [%(levelname)s] %(message)s",
    handlers=[
        logging.StreamHandler()
    ]
)
logger = logging.getLogger(__name__)

def resolve_encoded_file(encoded_data_dir: str, scratch_dir: str | None = None) -> str:
    """
    Resolves the encoded data directory to a single CatBoost-readable training file.
    Accepts plain `.tsv` files regardless of basename, or extensionless `part-*` files.
    Multiple files are merged deterministically because CatBoost expects one training file.
    Gzipped files are rejected explicitly because CatBoost cannot read them.
    """
    encoded_file, _ = _resolve_encoded_training_input(encoded_data_dir, scratch_dir)
    return str(encoded_file)


def _resolve_encoded_training_input(encoded_data_dir: str, scratch_dir: str | None) -> tuple[Path, list[Path]]:
    if not os.path.isdir(encoded_data_dir):
        raise ValueError(f"Encoded directory does not exist: {encoded_data_dir}")

    encoded_dir = Path(encoded_data_dir)
    entries = sorted(path for path in encoded_dir.iterdir() if path.is_file())
    encoded_files: list[Path] = []
    gzipped_files: list[Path] = []

    for path in entries:
        name = path.name
        if name.endswith(".tsv"):
            encoded_files.append(path)
            continue
        if name.startswith("part-") and "." not in name:
            encoded_files.append(path)
            continue
        if _is_rejected_gzip_candidate(path):
            gzipped_files.append(path)

    if gzipped_files:
        gzipped_names = ", ".join(path.name for path in gzipped_files)
        raise ValueError(
            "CatBoost training does not support gzipped encoded files. "
            f"Found: {gzipped_names}. Write plain .tsv output instead."
        )

    if not encoded_files:
        raise ValueError(
            f"No CatBoost-readable encoded files found in encoded directory: {encoded_data_dir}. "
            "Expected at least one plain .tsv file or extensionless part-* file."
        )

    if len(encoded_files) > 1 and scratch_dir is None:
        raise ValueError(
            f"CatBoost training requires exactly one encoded file, but found {len(encoded_files)} in {encoded_data_dir}. "
            "Pass scratch_dir to merge multiple encoded shards."
        )

    if len(encoded_files) == 1:
        return encoded_files[0], encoded_files

    return _merge_encoded_files(encoded_files, Path(scratch_dir)), encoded_files


def _merge_encoded_files(encoded_files: list[Path], scratch_dir: Path) -> Path:
    scratch_dir.mkdir(parents=True, exist_ok=True)
    merged_file = scratch_dir / "catboost_train_encoded.tsv"
    if any(encoded_file.resolve() == merged_file.resolve() for encoded_file in encoded_files):
        raise ValueError(f"Merged CatBoost training file would overwrite an input shard: {merged_file}")
    with merged_file.open("wb") as output:
        subprocess.run(["cat", *[str(encoded_file) for encoded_file in encoded_files]], stdout=output, check=True)
    logger.info("Merged %s encoded shards into %s", len(encoded_files), merged_file)
    return merged_file


def _is_rejected_gzip_candidate(path: Path) -> bool:
    return path.name.endswith(".gz")


def run_catboost_train(
        algorithm_definition_path: str,
        algorithm_definition: dict[str, Any],
        algorithm_jar_path: str,
        encoded_data_file_path: str,
        encoded_schema_description_file_path: str,
        scratch_dir: str,
        parameter_output_path: str) -> dict[str, Any]:
    encoded_data_path, encoded_files = _resolve_encoded_training_input(encoded_data_file_path, scratch_dir=scratch_dir)
    encoded_data_file = str(encoded_data_path)
    logger.info(
        f"Running catboost training encoded_data_file={encoded_data_file}, scratch_dir={scratch_dir}, parameter_location={parameter_output_path}")
    logger.info(f"Using column description: {encoded_schema_description_file_path}")

    training_data = Pool(encoded_data_file, column_description=encoded_schema_description_file_path)
    catboost_options = {
        "train_dir": scratch_dir
    }
    overrides = copy.deepcopy(algorithm_definition.get("catboost_options", {}))
    catboost_options.update(overrides)

    task_type = algorithm_definition.get("algorithm_parameters", {}).get("task_type", "classification")
    if task_type == "learn_to_rank":
        logger.info("CatBoostRanker model")
        model = CatBoostRanker(**catboost_options)
    elif task_type == "regression":
        logger.info("CatBoostRegressor model")
        model = CatBoostRegressor(**catboost_options)
    elif task_type == "classification":
        logger.info("CatBoostClassifier model")
        model = CatBoostClassifier(**catboost_options)
    else:
        raise ValueError(f"Task type {task_type} not available. Available options: learn_to_rank, regression, classification")
    logger.info("Starting the training")
    model.fit(training_data)
    logger.info("Saving the model")
    parameter_output_dir = Path(parameter_output_path)
    if parameter_output_dir.suffix:
        raise ValueError(
            f"Expected --parameter_output_path to be a directory (e.g. .../model_parameter), got: {parameter_output_path}"
        )
    parameter_output_dir.mkdir(parents=True, exist_ok=True)
    model_path = str(parameter_output_dir / "model.parameter")
    model.save_model(model_path)

    catboost_training_json = get_catboost_train_info(scratch_dir)
    result_json = {
        'parameter_output_path': parameter_output_path,
        'model_path': model_path,
        'encoded_data_file': encoded_data_file,
        'encoded_input_file_count': len(encoded_files),
        'encoded_input_files': [str(encoded_file) for encoded_file in encoded_files],
        'encoded_shards_merged': len(encoded_files) > 1,
        'catboost_training': catboost_training_json
    }
    return result_json


def load_json(json_path: str) -> dict[str, Any]:
    with open(json_path) as f:
        return json.load(f)


def get_catboost_train_info(scratch_dir: str):
    try:
        txt = Path(f'{scratch_dir}/catboost_training.json').read_text()
        # Apparently sometimes excessive new lines are added
        txt = txt.strip()
        try:
            return json.loads(txt)
        except JSONDecodeError:
            return {"error": f"catboost_training.json not parsable. Content:{txt}"}
    except FileNotFoundError:
        return {"error": f"catboost_training.json not found. Found only:{glob.iglob('sagemaker_catboost_container', recursive=True)}"}


if __name__ == '__main__':
    parser = argparse.ArgumentParser()
    parser.add_argument("--algorithm_definition_path", type=str, required=True)
    parser.add_argument("--algorithm_jar_path", type=str, required=True)
    parser.add_argument("--encoded_data_file_path", type=str, required=True)
    parser.add_argument("--encoded_schema_description_file_path", type=str, required=True)
    parser.add_argument("--scratch_dir", type=str, required=True)
    parser.add_argument("--parameter_output_path", type=str, required=True)

    args = parser.parse_args()

    try:
        algorithm_definition = load_json(args.algorithm_definition_path)
        result = run_catboost_train(
            algorithm_definition_path=args.algorithm_definition_path,
            algorithm_definition=algorithm_definition,
            algorithm_jar_path=args.algorithm_jar_path,
            encoded_data_file_path=args.encoded_data_file_path,
            encoded_schema_description_file_path=args.encoded_schema_description_file_path,
            scratch_dir=args.scratch_dir,
            parameter_output_path=args.parameter_output_path,
        )
        print(json.dumps(result))
    except:
        exc_info = sys.exc_info()
        error = json.dumps({"error": ''.join(traceback.format_exception(*exc_info))})
        sys.exit(error)
