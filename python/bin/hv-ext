#!/usr/bin/env python3
"""
hv-ext: Extended utilities for hotvect ML operations

This tool provides additional command-line utilities that support
hotvect workflows but are not part of the core functionality.
"""

import sys

try:
    from hotvect.extra.cli import main
except ModuleNotFoundError as e:  # pragma: no cover - runtime UX guard
    if e.name == "hotvect":
        print(
            "Error: hotvect is not installed in this Python environment.\n"
            "Install it first (for example from the repository root):\n"
            "  cd python && uv pip install -e .",
            file=sys.stderr,
        )
        raise SystemExit(1) from e
    raise

if __name__ == "__main__":
    main()
